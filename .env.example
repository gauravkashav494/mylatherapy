# ============================================================================
#  Concierge Quiz — server config template
#  Copy to `.env` and fill in real values. `.env` is gitignored.
# ============================================================================

# --- GoHighLevel (Private Integration Token + IDs) ---
GHL_TOKEN=pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GHL_LOCATION_ID=
GHL_CALENDAR_ID=
GHL_WEBHOOK=https://services.leadconnectorhq.com/hooks/.../webhook-trigger/...
GHL_TIMEZONE=America/Los_Angeles
GHL_SLOT_MINUTES=45
GHL_ASSIGNED_USER_ID=
GHL_MIN_NOTICE_MINUTES=60
GHL_MAX_MONTHS_AHEAD=3

# --- Email (SMTP). Leave blank to skip Astro-side email (GHL webhook still fires). ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM_EMAIL=noreply@mylatherapy.com
MAIL_FROM_NAME=My LA Therapy
ADMIN_EMAILS=hi@mylatherapy.com
