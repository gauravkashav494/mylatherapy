---
const pills = ['C-Suite, Tech & Founders', 'Industry Executives', 'Young Professionals'];
const cards = [
  { title: 'Perfectionists &<br>overthinkers', quote: 'Nothing you do ever feels like enough.', shadow: 'linear-gradient(165deg,var(--gold-4),var(--clay))', rule: 'var(--gold-2)' },
  { title: 'Overwhelmed<br>overachievers', quote: 'Successful on paper, running on empty.', shadow: 'linear-gradient(165deg,var(--sage-2),var(--sage-3))', rule: 'var(--sage-deep)' },
  { title: 'Anxiously attached<br>people-pleasers', quote: 'You say yes when every part of you means no.', shadow: 'linear-gradient(165deg,var(--gold-3),var(--gold))', rule: 'var(--gold)' },
  { title: 'High-functioning<br>trauma survivors', quote: 'Holding it all together — and holding it alone.', shadow: 'linear-gradient(165deg,var(--terracotta-2),var(--terracotta-3))', rule: 'var(--terracotta)' },
];
---
<section style="background:var(--cream);padding:34px 36px;" class="pad-fluid">
  <div style="max-width:1180px;margin:0 auto;background:var(--forest);border-radius:24px;padding:54px 44px;text-align:center;color:var(--cream-text);">
    <div style="font-size:13px;letter-spacing:.14em;text-transform:uppercase;color:var(--tan);font-weight:600;margin-bottom:12px;">Who we help</div>
    <h2 class="h2-fluid" style="font-family:var(--serif);font-weight:500;font-size:48px;line-height:1.05;margin:0 0 12px;color:var(--white);">Therapy for makers, doers<br><span style="font-style:italic;color:var(--tan);">&amp; dreamers.</span></h2>
    <p style="font-size:16px;line-height:1.6;color:var(--sage-pale);margin:0 auto 24px;max-width:580px;">The people we help, who we know by heart.</p>
    <div style="display:flex;flex-wrap:wrap;gap:10px;justify-content:center;max-width:820px;margin:0 auto 34px;">
      {pills.map((p) => <span style="background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.18);border-radius:999px;padding:8px 16px;font-size:14px;color:var(--cream-text);">{p}</span>)}
    </div>
    <div class="grid-4" style="display:grid;grid-template-columns:repeat(4,1fr);grid-auto-rows:1fr;gap:14px;max-width:940px;margin:0 auto 28px;">
      {cards.map((c) => (
        <div style="position:relative;">
          <div style={`position:absolute;inset:0;transform:translate(4px,5px);background:${c.shadow};border-radius:16px;`}></div>
          <div style="position:relative;z-index:1;height:100%;background:linear-gradient(178deg,var(--paper-4) 0%,var(--paper-5) 58%,var(--paper-6) 100%);border:1px solid var(--paper-7);border-radius:16px;padding:50px 18px;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;gap:13px;box-shadow:0 16px 34px -16px rgba(11,23,18,.6);">
            <span style={`width:48px;height:1px;background:${c.rule};flex:none;`}></span>
            <div style="font-family:var(--serif);font-weight:500;font-size:18px;line-height:1.2;color:var(--forest-ink);" set:html={c.title}></div>
            <div style="font-family:var(--serif);font-style:italic;font-size:14px;line-height:1.4;color:var(--sage-ink);">{c.quote}</div>
          </div>
        </div>
      ))}
    </div>
    <a href="#" class="link-underline" style="color:var(--tan);font-weight:600;font-size:15px;">See everyone we work with →</a>
  </div>
</section>
