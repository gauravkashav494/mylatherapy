---
// Founder's signature approach — Nervous System-Based Therapy, with constellation motif
---
<section style="background:var(--cream);padding:26px 36px 34px;border-top:1px solid var(--border);" class="pad-fluid">
  <div class="split" style="align-items:center;border-radius:24px;padding:36px 42px;display:grid;grid-template-columns:1.55fr 1fr;gap:30px;background:var(--forest);max-width:1140px;margin:0 auto;">
    <div>
      <div style="font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:var(--tan);font-weight:600;margin-bottom:11px;">Our founder’s signature approach</div>
      <h3 style="font-family:var(--serif);font-weight:500;font-size:31px;line-height:1.08;margin:0 0 12px;color:var(--white);">Nervous System-Based Therapy</h3>
      <p style="font-size:15px;line-height:1.62;color:var(--sage-pale);margin:0 0 18px;max-width:540px;">Our signature approach developed by our founder — working in real-time with the nervous system to interrupt the unconscious patterns beneath the surface to translate insight into lasting, embodied change.</p>
      <div style="display:flex;align-items:center;gap:9px;font-size:13px;color:var(--sage-pale);margin:0 0 18px;"><span style="display:inline-flex;align-items:center;justify-content:center;width:18px;height:18px;border-radius:50%;background:linear-gradient(135deg,var(--gold-3),var(--gold));color:var(--white);font-size:10px;line-height:1;flex:none;">✓</span><span>Developed by our founder <strong style="font-family:var(--serif);font-style:italic;font-weight:500;color:var(--white);">Brooke Sprowl, LCSW</strong></span></div>
      <a href="#methods" class="link-underline" style="color:var(--white);font-weight:600;font-size:14.5px;">Explore our signature method →</a>
    </div>
    <div style="display:flex;align-items:center;justify-content:center;">
      <svg width="190" height="190" viewBox="0 0 158 158" fill="none">
        <circle cx="79" cy="78" r="62" fill="none" style="stroke:var(--tan)" stroke-opacity=".22" stroke-width="1.4"></circle>
        <circle cx="79" cy="78" r="44" fill="none" style="stroke:var(--tan)" stroke-opacity=".12" stroke-width="1.2"></circle>
        <g style="stroke:var(--tan)" stroke-width="1" stroke-opacity=".4">
          <line x1="115.4" y1="47.5" x2="96.0" y2="33.7"></line><line x1="115.4" y1="47.5" x2="97.6" y2="65.4"></line>
          <line x1="104.3" y1="90.1" x2="93.5" y2="86.7"></line><line x1="104.3" y1="90.1" x2="111.5" y2="102.8"></line>
          <line x1="91.2" y1="69.8" x2="75.3" y2="68.1"></line><line x1="91.2" y1="69.8" x2="105.6" y2="77.6"></line>
          <line x1="64.5" y1="64.0" x2="54.3" y2="51.4"></line><line x1="56.3" y1="78.4" x2="65.2" y2="88.6"></line>
          <line x1="111.5" y1="102.8" x2="92.1" y2="100.2"></line><line x1="71.4" y1="100.5" x2="83.0" y2="95.2"></line>
          <line x1="124.3" y1="86.5" x2="105.6" y2="77.6"></line><line x1="95.8" y1="119.4" x2="92.1" y2="100.2"></line>
          <line x1="69.7" y1="42.7" x2="64.5" y2="64.0"></line><line x1="93.5" y1="86.7" x2="83.0" y2="95.2"></line>
          <line x1="54.3" y1="51.4" x2="67.3" y2="43.9"></line><line x1="46.0" y1="105.7" x2="56.4" y2="94.3"></line>
          <line x1="86.5" y1="118.0" x2="75.4" y2="101.8"></line><line x1="29.8" y1="76.6" x2="56.3" y2="78.4"></line>
          <line x1="75.4" y1="101.8" x2="65.2" y2="88.6"></line><line x1="92.1" y1="100.2" x2="104.3" y2="90.1"></line>
        </g>
        <g style="fill:var(--tan)" stroke="none">
          <circle cx="115.4" cy="47.5" r="2.2"></circle><circle cx="104.3" cy="90.1" r="2.2"></circle>
          <circle cx="91.2" cy="69.8" r="1.5"></circle><circle cx="56.8" cy="101.8" r="2.6"></circle>
          <circle cx="64.5" cy="64.0" r="2.6"></circle><circle cx="65.2" cy="88.6" r="2.0"></circle>
          <circle cx="56.3" cy="78.4" r="1.8"></circle><circle cx="111.5" cy="102.8" r="1.3"></circle>
          <circle cx="71.4" cy="100.5" r="2.6"></circle><circle cx="124.3" cy="86.5" r="1.8"></circle>
          <circle cx="95.8" cy="119.4" r="2.4"></circle><circle cx="93.5" cy="86.7" r="2.3"></circle>
          <circle cx="73.5" cy="82.0" r="2.5"></circle><circle cx="54.3" cy="51.4" r="2.7"></circle>
          <circle cx="46.0" cy="105.7" r="2.2"></circle><circle cx="56.4" cy="94.3" r="2.1"></circle>
          <circle cx="83.0" cy="95.2" r="2.4"></circle><circle cx="86.5" cy="118.0" r="2.4"></circle>
          <circle cx="110.4" cy="47.3" r="2.7"></circle><circle cx="29.8" cy="76.6" r="2.7"></circle>
          <circle cx="92.1" cy="100.2" r="2.4"></circle>
        </g>
        <circle cx="79" cy="78" r="7" style="fill:var(--terracotta)"></circle>
      </svg>
    </div>
  </div>
</section>
