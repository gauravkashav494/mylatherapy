---
// "We help you turn insight into action" — video + copy
import VideoPlayer from './VideoPlayer.tsx';
---
<section class="split pad-fluid" style="padding:72px 36px 36px;display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center;">
  <VideoPlayer client:visible />
  <div>
    <div style="font-size:13px;letter-spacing:.14em;text-transform:uppercase;color:var(--terracotta);font-weight:600;margin-bottom:16px;">Insight into action</div>
    <h2 class="h2-fluid" style="font-family:var(--serif);font-weight:500;font-size:42px;line-height:1.1;letter-spacing:-.01em;margin:0 0 18px;color:var(--forest-ink);">We help you turn insight into action.&nbsp;</h2>
    <p style="font-size:18px;line-height:1.6;color:var(--muted);margin:0 0 18px;">You're self-aware. You've read the books — maybe done years of therapy. What you're tired of is the polite hour of nodding that ends right where it began.</p>
    <p style="font-size:18px;line-height:1.6;color:var(--muted);margin:0;">We match you with therapists who listen <em>and then challenge you</em> — turning insight into action with specialized, evidence-based tools. Real feedback. A plan. Change you can actually feel.</p>
  </div>
</section>
