---
// "We help you turn insight into action" — video + copy
import VideoPlayer from './VideoPlayer.tsx';
---
<section class="split pad-fluid" style="padding:72px 36px 36px;display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center;">
  <VideoPlayer client:visible />
  <div>
    <div style="font-size:13px;letter-spacing:.14em;text-transform:uppercase;color:var(--terracotta);font-weight:600;margin-bottom:16px;">Insight into action</div>
    <h2 class="h2-fluid" style="font-family:var(--serif);font-weight:500;font-size:42px;line-height:1.1;letter-spacing:-.01em;margin:0 0 18px;color:var(--forest-ink);">Insight alone won't change your life.&nbsp;</h2>
    <p style="font-size:18px;line-height:1.6;color:var(--muted);margin:0 0 18px;">We help self-aware people turn hard-won insight into lasting change. We use research-based tools to help insightful people break free of anxiety, depression, trauma, and unhealthy relationship patterns so they can cultivate newfound presence, aliveness, and connection.</p>
    <p style="font-size:18px;line-height:1.6;color:var(--muted);margin:0;">Insight lives in the mind, but the patterns that run our lives operate beneath conscious awareness. That's why our therapists go beyond traditional talk therapy — working at the nervous-system level with somatic, experiential, and attachment-based methods to help you move beyond the intellect and into actionable change.</p>
  </div>
</section>
