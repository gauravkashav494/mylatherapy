---
const features = [
  {
    icon: '<path d="M12 3l7 3v5c0 4.5-3 7.6-7 9-4-1.4-7-4.5-7-9V6l7-3z"></path><path d="M9 12l2 2 4-4"></path>',
    title: 'Love your therapist — or your money back.',
    body: "We're so confident in our extraordinary therapists we do what no other practice will: we offer a money back guarantee on the first session. If for any reason you feel your therapist isn't the right fit, we give you a full refund on the first session no questions asked.",
  },
  {
    icon: '<path d="M13 2L3 14h7l-1 8 10-12h-7l1-8z"></path>',
    title: 'We don’t just listen. We challenge you.',
    body: 'While many therapists simply listen passively and provide empathy, we take an active role in therapy, recognizing that meaningful and enduring change comes from challenging you to think and exist differently. We provide research-based tools, practical feedback, and actionable advice.',
  },
  {
    icon: '<path d="M3 12h3l2 6 4-13 3 9 2-4h4"></path>',
    title: 'Therapy that goes beyond the intellect.',
    body: 'Understanding your problems rarely changes them. Our team is specially trained in Nervous System-Based Therapy — identifying and interrupting the unconscious patterns, anxiety, and defenses that keep you stuck in real time. So change takes hold in your body, not just your understanding.',
  },
  {
    icon: '<path d="M9 11l3 3 8-8"></path><path d="M20 12v7a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h9"></path>',
    title: 'Therapist-founded, not tech-owned.',
    body: "Most therapy companies are run by tech bros. We're run by a therapist with 20 years of clinical experience who rigorously vets, trains, and selects each therapist. Each match is hand-selected by a real person based on your unique needs, personality, and preferences — not an algorithm.",
  },
];
---
<section style="background:var(--cream);padding:24px 44px 52px;" class="pad-fluid">
  <div style="background:var(--forest);border-radius:28px;padding:52px 44px;">
    <div style="text-align:center;margin-bottom:40px;">
      <div style="font-size:13px;letter-spacing:.14em;text-transform:uppercase;color:var(--sage-pale-2);font-weight:600;margin-bottom:14px;">What makes us different</div>
      <h2 class="h2-fluid" style="font-family:var(--serif);font-weight:500;font-size:40px;line-height:1.1;margin:0 auto;max-width:720px;color:var(--white);">The right therapist, matched to you — and <span style="font-style:italic;color:var(--tan-2);">backed by a guarantee.</span></h2>
    </div>
    <div class="grid-4" style="display:grid;grid-template-columns:repeat(4,1fr);gap:18px;">
      {features.map((f) => (
        <div style="background:rgba(246,241,233,.08);border:1px solid rgba(220,230,221,.16);border-radius:18px;padding:26px;">
          <div style="width:46px;height:46px;border-radius:12px;background:var(--terracotta);display:flex;align-items:center;justify-content:center;margin-bottom:16px;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" style="stroke:var(--white)" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={f.icon} />
          </div>
          <h3 style="font-family:var(--serif);font-weight:500;font-size:20px;line-height:1.18;margin:0 0 8px;color:var(--white);">{f.title}</h3>
          <p style="font-size:14.5px;line-height:1.55;color:var(--sage-pale);margin:0;">{f.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
