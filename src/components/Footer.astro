---
const columns = [
  {
    head: 'Who We Help',
    links: ['C-Suite & Founders', 'Industry Executives', 'Young Professionals', 'Artists & Creatives', 'Empaths & HSPs'],
  },
  {
    head: 'Specialties',
    links: ['Anxiety & OCD', 'Depression & Mood', 'Trauma & C-PTSD', 'Relationships & Couples', 'Child & Family Therapy'],
  },
  {
    head: 'Methods',
    links: ['Nervous System', 'EMDR', 'Somatic Therapy', 'CBT & DBT', 'Hypnotherapy'],
  },
  {
    head: 'The Ecosystem',
    links: ['Our Team', 'Meet Brooke Sprowl', 'Soul Salon', 'Iconoclast', 'Reviews'],
  },
];

const offices = [
  { name: 'Santa Monica', line1: '720 Wilshire Blvd', line2: 'Santa Monica, CA 90401' },
  { name: 'West LA', line1: '11845 W Olympic Blvd', line2: 'Los Angeles, CA 90064' },
  { name: 'Beverly Hills', line1: '8500 Wilshire Blvd', line2: 'Beverly Hills, CA 90211' },
  { name: 'Studio City', line1: '11846 Ventura Blvd', line2: 'Studio City, CA 91604' },
  { name: 'Encino', line1: '16530 Ventura Blvd', line2: 'Encino, CA 91436' },
  { name: 'Echo Park', line1: '1910 Sunset Blvd', line2: 'Los Angeles, CA 90026' },
  { name: 'Pasadena', line1: '595 E Colorado Blvd', line2: 'Pasadena, CA 91101' },
  { name: 'Online', line1: 'Anywhere in Los Angeles', line2: '& California' },
];
---
<footer style="background:var(--forest);color:var(--sage-pale);border-radius:28px 28px 0 0;overflow:hidden;">
  <!-- top: CTA + link columns -->
  <div class="foot-top pad-fluid" style="background:var(--forest-mid);padding:56px 44px;">
    <div class="foot-grid" style="max-width:1300px;margin:0 auto;display:grid;grid-template-columns:1.5fr 1fr 1fr 1fr 1fr;gap:36px 30px;">
      <!-- CTA column -->
      <div>
        <div style="font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:var(--tan);font-weight:600;margin-bottom:14px;">Ready when you are</div>
        <h2 style="font-family:var(--serif);font-weight:500;font-size:30px;line-height:1.1;margin:0 0 22px;color:var(--white);">Let's find your <span style="font-style:italic;color:var(--tan);">perfect therapist.</span></h2>
        <a href="#book" class="btn btn-primary" style="text-decoration:none;display:inline-block;background:var(--terracotta);color:var(--white);font-weight:600;font-size:15.5px;padding:14px 28px;border-radius:999px;box-shadow:0 14px 30px -12px rgba(0,0,0,.4);">Find My Therapist →</a>
        <div style="display:flex;align-items:center;gap:9px;margin-top:22px;font-size:13px;color:var(--sage-soft);">
          <span style="display:inline-flex;align-items:center;justify-content:center;width:20px;height:20px;border-radius:50%;border:1px solid var(--sage-deep);color:var(--sage-soft);font-size:11px;flex:none;">✓</span>
          Founder-vetted · 20 years
        </div>
      </div>
      <!-- link columns -->
      {columns.map((col) => (
        <div>
          <div style="font-size:11.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--sage-soft);font-weight:600;margin-bottom:16px;">{col.head}</div>
          <div style="display:flex;flex-direction:column;gap:11px;">
            {col.links.map((l) => <a href={l === 'Our Team' ? '/our-team' : '#'} class="foot-link" style="color:var(--sage-pale);text-decoration:none;font-size:14.5px;">{l}</a>)}
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- offices -->
  <div class="pad-fluid" style="padding:40px 44px 30px;">
    <div style="max-width:1300px;margin:0 auto;">
      <div style="font-size:11.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--tan);font-weight:600;margin-bottom:22px;">Our Offices</div>
      <div class="foot-offices" style="display:grid;grid-template-columns:repeat(4,1fr);gap:26px 30px;">
        {offices.map((o) => (
          <div>
            <div style="display:flex;align-items:center;gap:7px;margin-bottom:6px;">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" style="stroke:var(--tan);flex:none;" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s7-5.5 7-11a7 7 0 1 0-14 0c0 5.5 7 11 7 11z"></path><circle cx="12" cy="10" r="2.4"></circle></svg>
              <span style="color:var(--white);font-weight:600;font-size:14px;">{o.name}</span>
            </div>
            <div style="font-size:13px;line-height:1.55;color:var(--sage-soft);">{o.line1}<br />{o.line2}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- copyright bar -->
  <div class="pad-fluid" style="padding:22px 44px 30px;">
    <div style="max-width:1300px;margin:0 auto;border-top:1px solid rgba(255,255,255,.1);padding-top:24px;display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;font-size:13px;color:var(--sage-soft);">
      <span>© 2026 My LA Therapy · A practice of Brooke Sprowl, LCSW</span>
      <span style="display:flex;gap:22px;flex-wrap:wrap;">
        <a href="#" class="foot-link" style="color:var(--sage-soft);text-decoration:none;">Privacy</a>
        <a href="#" class="foot-link" style="color:var(--sage-soft);text-decoration:none;">Terms</a>
        <a href="#" class="foot-link" style="color:var(--sage-soft);text-decoration:none;">Good Faith Estimate</a>
      </span>
    </div>
  </div>

  <style>
    .foot-link { transition: color .16s ease; }
    .foot-link:hover { color: var(--white); }

    @media (max-width: 700px) {
      .foot-grid { grid-template-columns: 1fr 1fr !important; }
      .foot-offices { grid-template-columns: 1fr 1fr !important; }
    }

    @media (max-width: 640px) {
      .foot-grid { grid-template-columns: 1fr !important; }
      .foot-offices { grid-template-columns: 1fr !important; }
    }
  </style>
</footer>
