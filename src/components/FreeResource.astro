---
// Lead magnet: "Mindset Mastery Guide" CBT workbook.
// GuidePages renders the real 6-page previews (cover + interior pages) as
// faithful scaled mini-renders, matching the original template.
import GuidePages from './GuidePages.astro';
---
<section style="background:linear-gradient(180deg,var(--cream) 0%,var(--mist) 100%);padding:40px 36px;" class="pad-fluid">
  <div style="max-width:900px;margin:0 auto;">
    <div style="background:var(--paper);border:1px solid var(--border-2);border-radius:20px;padding:38px 40px;box-shadow:0 24px 60px -34px rgba(33,58,48,.4);">
      <div class="split" style="display:grid;grid-template-columns:auto 1fr;gap:34px;align-items:center;margin-bottom:32px;">
        <!-- book cover (real scaled render) -->
        <GuidePages mode="cover" />
        <!-- copy + capture -->
        <div>
          <div style="font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--terracotta);font-weight:600;margin-bottom:10px;">Free resource for anxiety &amp; depression</div>
          <h3 style="font-family:var(--serif);font-weight:500;font-size:27px;line-height:1.1;color:var(--forest-ink);margin:0 0 12px;">Learn to quiet your most anxious thoughts.</h3>
          <p style="font-size:14px;line-height:1.6;color:var(--muted);margin:0 0 16px;max-width:430px;">Learn scientifically proven CBT techniques to overcome irrational thoughts — and see yourself in more empowering, peaceful, and realistic ways.</p>
          <form style="display:flex;gap:9px;max-width:400px;flex-wrap:wrap;" onsubmit="return false;">
            <input type="email" placeholder="Your email" style="flex:1;min-width:180px;background:var(--white);border:1px solid var(--border-5);border-radius:999px;padding:11px 18px;font-size:14px;color:var(--ink);font-family:var(--sans);" />
            <button class="btn btn-primary" style="border:none;cursor:pointer;background:var(--terracotta);color:var(--white);font-weight:600;font-size:14px;padding:11px 22px;border-radius:999px;font-family:var(--sans);">Download For Free</button>
          </form>
        </div>
      </div>

      <!-- inside the guide -->
      <div style="padding-top:24px;border-top:1px solid var(--border-2);">
        <div style="font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted-5);font-weight:600;margin-bottom:16px;">Inside the guide · 6 pages</div>
        <GuidePages mode="strip" />
      </div>
    </div>
  </div>
</section>
