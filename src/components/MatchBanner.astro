---
import MatchingForm from './MatchingForm.tsx';

const steps = [
  { n: 1, title: "You share what's going on", body: "A few details — that's this form." },
  { n: 2, title: 'We hand-match you', body: 'Our founder personally pairs you — usually same day.' },
  { n: 3, title: 'You meet, and decide', body: "If the fit isn't right, your first session's on us." },
];
---
<section id="book" style="background:var(--sand-2);padding:0 40px 40px;" class="pad-fluid">
  <!-- intro band -->
  <div class="pad-tight-sm match-band" style="background:linear-gradient(180deg,var(--cream) 0%,var(--sand-2) 100%);padding:80px 50px 60px;margin:0 -40px 0;">
    <div style="max-width:860px;margin:0 auto;text-align:center;">
      <div style="font-size:12px;letter-spacing:.2em;text-transform:uppercase;color:var(--terracotta);font-weight:600;margin-bottom:14px;">Every match, personally</div>
      <div class="h2-fluid" style="font-family:var(--serif);font-weight:500;font-size:42px;line-height:1.1;color:var(--forest-ink);">Twenty years of clinical experience <span style="font-style:italic;color:var(--terracotta);">behind every match.</span></div>
      <div style="display:flex;justify-content:center;align-items:center;flex-wrap:wrap;gap:14px 0;margin-top:24px;border-top:1px solid rgba(194,119,75,.28);padding-top:20px;">
        <div style="padding:0 24px;display:flex;align-items:baseline;gap:7px;"><span style="font-family:var(--serif);font-size:20px;color:var(--forest-ink);"><span style="color:var(--terracotta);">★</span> 4.9</span><span style="font-size:12.5px;color:var(--muted-4);">average rating</span></div>
        <div style="width:1px;height:22px;background:rgba(194,119,75,.28);"></div>
        <div style="padding:0 24px;display:flex;align-items:baseline;gap:7px;"><span style="font-family:var(--serif);font-size:20px;color:var(--forest-ink);">6,500+</span><span style="font-size:12.5px;color:var(--muted-4);">clients matched</span></div>
        <div style="width:1px;height:22px;background:rgba(194,119,75,.28);"></div>
        <div style="padding:0 24px;display:flex;align-items:baseline;gap:7px;"><span style="font-family:var(--serif);font-size:20px;color:var(--forest-ink);">100%</span><span style="font-size:12.5px;color:var(--muted-4);">match guarantee</span></div>
      </div>
    </div>
  </div>

  <!-- forest card: left copy + form -->
  <div class="pad-tight-sm" style="background:var(--forest);padding:84px 46px 72px;border-radius:28px;box-shadow:0 18px 64px -24px rgba(33,58,48,.4);">
    <div class="split" style="max-width:1080px;margin:0 auto;display:grid;grid-template-columns:1fr 1.05fr;gap:46px;align-items:center;">
      <div style="color:var(--cream-text);">
        <div style="font-family:var(--serif);font-style:italic;font-size:17px;color:var(--tan);margin-bottom:12px;">Hand-matched, on us</div>
        <h2 class="h2-fluid" style="font-family:var(--serif);font-weight:500;font-size:33px;line-height:1.1;letter-spacing:-.01em;color:var(--white);margin:0 0 14px;">Stop searching. <span style="font-style:italic;color:var(--tan);">We have your match.</span></h2>
        <p style="font-size:16px;line-height:1.6;color:var(--sage-pale);margin:0 0 24px;max-width:430px;">Tell us what's going on and a real person hand-matches you to the specialist who fits — usually within 24–48 hours.</p>
        <div style="display:flex;flex-direction:column;gap:18px;margin-bottom:26px;">
          {steps.map((s) => (
            <div style="display:flex;gap:14px;align-items:flex-start;">
              <span style="width:34px;height:34px;border-radius:50%;background:var(--tan);color:var(--forest-ink);font-family:var(--serif);font-size:17px;font-weight:600;display:flex;align-items:center;justify-content:center;flex:none;">{s.n}</span>
              <div><div style="font-weight:700;font-size:15px;color:var(--white);line-height:1.2;margin-bottom:3px;">{s.title}</div><div style="font-size:13.5px;line-height:1.5;color:var(--sage-soft);">{s.body}</div></div>
            </div>
          ))}
        </div>
        <div style="border-top:1px solid rgba(255,255,255,.13);padding-top:20px;max-width:440px;">
          <div style="color:var(--tan);font-size:13px;letter-spacing:2px;margin-bottom:8px;">★★★★★</div>
          <blockquote style="margin:0 0 8px;font-family:var(--serif);font-size:16.5px;line-height:1.5;color:var(--cream-text);">"I was in therapy on and off for 20 years. Brooke did more in one session than years of work with my previous therapists."</blockquote>
          <div style="font-size:13px;line-height:1.5;color:var(--sage-soft);">— Client, Santa Monica</div>
        </div>
      </div>

      <MatchingForm client:visible />
    </div>
  </div>
</section>
