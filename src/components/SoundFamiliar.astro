---
// tail color = the little speech-bubble pointer under each card
const cards = [
  { text: '"I get it all in my head — I just can’t change my patterns."', bg: 'var(--white)', color: 'var(--forest)', border: '2.5px solid var(--terracotta)', tail: 'var(--terracotta)', tailSide: 'left', innerTail: true },
  { text: '"On paper my life looks great. Underneath, I feel empty."', bg: 'var(--forest)', color: 'var(--cream)', tail: 'var(--forest)', tailSide: 'right' },
  { text: '"I’ve done years of therapy. I understand myself. I’m still stuck."', bg: 'var(--white)', color: 'var(--forest)', border: '2.5px solid var(--sage)', tail: 'var(--sage)', tailSide: 'left', innerTail: true },
  { text: '"My mind won’t stop racing — I can’t turn it off."', bg: 'var(--terracotta)', color: 'var(--cream)', tail: 'var(--terracotta)', tailSide: 'right' },
  { text: '"I keep ending up in the same relationship, different person."', bg: 'var(--white)', color: 'var(--forest)', border: '2.5px solid var(--forest)', tail: 'var(--forest)', tailSide: 'left', innerTail: true },
  { text: '"I’m successful, but I’m exhausted — and I can’t tell anyone."', bg: 'var(--sage-deep)', color: 'var(--cream)', tail: 'var(--sage-deep)', tailSide: 'right' },
];
---
<section style="background:var(--mist);padding:72px 36px;border-top:1px solid var(--border);" class="pad-fluid">
  <div style="text-align:center;max-width:680px;margin:0 auto 46px;">
    <div style="font-size:13px;letter-spacing:.14em;text-transform:uppercase;color:var(--terracotta);font-weight:600;margin-bottom:14px;">Sound familiar?</div>
    <h2 class="h2-fluid" style="font-family:var(--serif);font-weight:500;font-size:40px;line-height:1.06;margin:0;color:var(--forest-ink);">Does this sound <span style="font-style:italic;color:var(--terracotta);">like you?</span></h2>
  </div>
  <div class="grid-3" style="display:grid;grid-template-columns:repeat(3,1fr);gap:34px 28px;max-width:1004px;margin:0 auto;">
    {cards.map((c) => (
      <div style={`position:relative;background:${c.bg};${c.border ? `border:${c.border};` : ''}border-radius:20px;padding:34px 24px;display:flex;align-items:center;justify-content:center;text-align:center;min-height:150px;${!c.border ? 'box-shadow:0 14px 30px -20px rgba(33,58,48,.5);' : ''}`}>
        <p style={`margin:0;font-family:var(--serif);font-weight:500;font-size:21px;line-height:1.32;color:${c.color};`}>{c.text}</p>
        {c.tailSide === 'left' ? (
          <div style={`position:absolute;left:34px;bottom:-19px;width:0;height:0;border-left:17px solid transparent;border-right:17px solid transparent;border-top:19px solid ${c.tail};`}></div>
        ) : (
          <div style={`position:absolute;right:40px;bottom:-15px;width:0;height:0;border-left:16px solid transparent;border-right:16px solid transparent;border-top:18px solid ${c.tail};`}></div>
        )}
        {c.innerTail && <div style="position:absolute;left:38px;bottom:-12px;width:0;height:0;border-left:13px solid transparent;border-right:13px solid transparent;border-top:15px solid var(--white);"></div>}
      </div>
    ))}
  </div>
  <div style="text-align:center;margin-top:42px;">
    <p style="font-size:18px;line-height:1.5;color:var(--taupe-4);margin:0;font-family:var(--serif);font-style:italic;">If you're nodding — that's exactly where we begin.</p>
  </div>
</section>
