---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.tsx';
import Footer from '../components/Footer.astro';
/**
 * /quiz — Concierge Lead Capture. Faithful port of the WordPress shortcode
 * [quiz_rough_form_new_1] (quiz-frontend-1.php). Markup + CSS + JS are the
 * same; only the AJAX layer is rewired from admin-ajax.php to the Astro API
 * routes under /api/*. Backend logic lives in src/lib/ghl.ts + src/lib/email.ts.
 */
---
<Layout
  title="Find Your Therapist Match — My LA Therapy"
  description="Answer a few questions and our team hand-matches you with the right Los Angeles therapist — or book a free 30-minute call. Founder-vetted. Your first session's on us."
  path="/quiz"
>
  <div id="top">
    <Nav client:load />

    <main>
      <div class="bsq" id="bsqApp">

        <!-- ================= PROOF BAND ================= -->
        <section class="bsq-proof">
          <div class="bsq-proof-in">
            <div class="bsq-eyebrow">Every match, personally</div>
            <div class="bsq-proof-h">Twenty years of clinical experience <em>behind every match.</em></div>
            <div class="bsq-stats">
              <div class="bsq-stat"><b><i>&#9733;</i> 4.9</b><span>average rating</span></div>
              <div class="bsq-stat-sep"></div>
              <div class="bsq-stat"><b>6,500+</b><span>clients matched</span></div>
              <div class="bsq-stat-sep"></div>
              <div class="bsq-stat"><b>100%</b><span>match guarantee</span></div>
            </div>
          </div>
        </section>

        <div class="bsq-stage">
          <div class="bsq-card">

            <!-- ============ SCREEN 1 — CAPTURE ============ -->
            <div class="bsq-screen on" id="scCapture">
              <div class="bsq-rail">
                <div class="bsq-rail-mid">
                  <div class="bsq-rail-eyebrow">Hand-matched, on us</div>
                  <h3>Stop searching. We&rsquo;ll do it for you.</h3>
                  <div class="bsq-steps">
                    <div class="bsq-step"><span>1</span><div><b>You share what&rsquo;s going on</b><em>A few details &mdash; that&rsquo;s this form.</em></div></div>
                    <div class="bsq-step"><span>2</span><div><b>We hand-match you</b><em>To the specialist who fits &mdash; usually same day.</em></div></div>
                    <div class="bsq-step"><span>3</span><div><b>You meet, and decide</b><em>Love your therapist, or your money back.</em></div></div>
                  </div>
                </div>
                <div class="bsq-testi">
                  <div class="bsq-testi-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
                  <blockquote>&ldquo;I was in therapy on and off for 20 years. Brooke did more in one session than years of work with my previous therapists.&rdquo;</blockquote>
                  <cite>&mdash; Client, Santa Monica</cite>
                </div>
              </div>

              <div class="bsq-field">
                <h3>Let&rsquo;s find your perfect match.</h3>
                <div class="bsq-trust">
                  <i>&#10003;</i>
                  <span>Every therapist trained by our founder&nbsp;<b>Brooke Sprowl, LCSW</b> <span class="sep">&middot;</span> 20 years in practice</span>
                </div>

                <div class="bsq-row">
                  <div>
                    <label class="bsq-label" for="bsqFirst">First name *</label>
                    <input type="text" id="bsqFirst" name="firstName" placeholder="First name" autocomplete="given-name">
                  </div>
                  <div>
                    <label class="bsq-label" for="bsqEmail">Email *</label>
                    <input type="email" id="bsqEmail" name="email" placeholder="you@email.com" autocomplete="email">
                  </div>
                </div>
                <p class="bsq-err" id="bsqErrCapture"></p>

                <div class="bsq-group-label">What&rsquo;s bringing you in? *</div>
                <div class="bsq-pills" data-group="concerns">
                  <label class="bsq-pill"><input type="checkbox" value="Anxiety">Anxiety</label>
                  <label class="bsq-pill"><input type="checkbox" value="Depression">Depression</label>
                  <label class="bsq-pill"><input type="checkbox" value="Trauma">Trauma</label>
                  <label class="bsq-pill"><input type="checkbox" value="Communication issues">Relationships</label>
                  <label class="bsq-pill"><input type="checkbox" value="Couples Counseling">Couples</label>
                  <label class="bsq-pill"><input type="checkbox" value="Child/Teen">Child/Teen</label>
                  <label class="bsq-pill"><input type="checkbox" value="Grief and Loss">Family</label>
                  <label class="bsq-pill"><input type="checkbox" value="Other">Other</label>
                </div>
                <p class="bsq-err" id="bsqErrConcerns"></p>

                <div style="margin-bottom:24px;">
                  <div class="bsq-group-label">Preferred location</div>
                  <select id="bsqLocation" name="location">
                    <option value="">Choose a location&hellip;</option>
                    <option>Santa Monica</option>
                    <option>West LA</option>
                    <option>Beverly Hills</option>
                    <option>Encino</option>
                    <option>Studio City</option>
                    <option>Pasadena</option>
                    <option>Echo Park</option>
                    <option>Online (anywhere in CA)</option>
                  </select>
                </div>

                <button type="button" class="bsq-cta" id="bsqCaptureNext">Continue &rarr;</button>
                <div class="bsq-micro">Free &amp; confidential &middot; Love your therapist or your money back &middot; 6,500+ matched</div>
              </div>
            </div>

            <!-- ============ SCREEN 2 — CHOOSE YOUR PATH ============ -->
            <div class="bsq-screen" id="scPath">
              <div class="bsq-rail">
                <div class="bsq-ticks"><i></i><i></i></div>
                <div class="bsq-thanks">
                  <i>&#10003;</i>
                  <span>Thanks, <b class="bsq-name">there</b> &mdash; your details are in.</span>
                </div>
                <div class="bsq-rail-eyebrow">One last thing</div>
                <h3>You&rsquo;re one step from your match.</h3>
                <p>Either way, a real person reviews your details and hand-selects your therapist &mdash; guaranteed.</p>
                <div class="bsq-testi">
                  <div class="bsq-testi-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
                  <blockquote>&ldquo;Brooke has the true gift of insight and compassion &mdash; getting straight to the heart of your blind spots in a way that&rsquo;s truly changed my life.&rdquo;</blockquote>
                  <cite>&mdash; Client, Santa Monica</cite>
                </div>
              </div>

              <div class="bsq-field">
                <h3>How would you like to get matched?</h3>
                <p class="bsq-lede">Both are free. Most people are matched within 24&ndash;48 hours.</p>
                <div class="bsq-paths">
                  <button type="button" class="bsq-path primary" data-path="call">
                    <span class="bsq-path-icon">&#128197;</span>
                    <span class="bsq-path-body">
                      <span class="bsq-path-top"><b>Talk it through</b><span class="bsq-badge">Most popular</span></span>
                      <p>Book a free 30-min call. We get to know you and guide you to the right specialist.</p>
                      <small>Best if you&rsquo;d like a person to walk you through it.</small>
                    </span>
                    <span class="bsq-path-arrow">&rarr;</span>
                  </button>
                  <button type="button" class="bsq-path" data-path="self">
                    <span class="bsq-path-icon warm">
                      <svg width="23" height="23" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <defs><linearGradient id="bsqSpk" x1="2" y1="2" x2="22" y2="22">
                          <stop offset="0" stop-color="#C2774B"></stop><stop offset="1" stop-color="#9A5A33"></stop>
                        </linearGradient></defs>
                        <path d="M12 1.4l2 6.6 6.6 2-6.6 2-2 6.6-2-6.6-6.6-2 6.6-2z" fill="url(#bsqSpk)"></path>
                        <path d="M19.2 13.6l.85 2.75 2.75.85-2.75.85-.85 2.75-.85-2.75-2.75-.85 2.75-.85z" fill="url(#bsqSpk)" opacity=".85"></path>
                      </svg>
                    </span>
                    <span class="bsq-path-body">
                      <span class="bsq-path-top"><b>Match me now</b></span>
                      <p>Answer a few more questions and we&rsquo;ll hand-select your match &mdash; no call needed.</p>
                      <small>Best if you&rsquo;d rather start on your own.</small>
                    </span>
                    <span class="bsq-path-arrow">&rarr;</span>
                  </button>
                </div>
                <div class="bsq-micro">Not sure? <b id="bsqStartCall">Start with a call</b> &mdash; you can always switch.</div>
              </div>
            </div>

            <!-- ============ SCREEN 3A — SCHEDULE A CALL ============ -->
            <div class="bsq-screen" id="scCall">
              <div class="bsq-rail">
                <div class="bsq-ticks"><i></i></div>
                <div class="bsq-rail-eyebrow">Your free consult</div>
                <h3>Let&rsquo;s get you on the calendar.</h3>
                <p>A real 30-minute conversation to understand exactly what you&rsquo;re working through &mdash; so we can match you with a therapist who specializes in your concerns and fits your schedule, your style, and your life.</p>
                <div class="bsq-testi">
                  <div class="bsq-testi-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
                  <blockquote>&ldquo;You did more in 45 minutes than my last therapist did in a year!&rdquo;</blockquote>
                  <cite>&mdash; D.L., Hollywood Hills</cite>
                </div>
              </div>

              <div class="bsq-field">
                <h3>Book your free 30-minute call.</h3>
                <p class="bsq-lede">Pick a day and time &mdash; we&rsquo;ll hand-match you by the end of the call.</p>
                <div class="bsq-note" id="bsqCalNote"></div>

                <div class="bsq-cal-grid">
                  <div>
                    <div class="bsq-cal-cap">Choose a date</div>
                    <div class="bsq-cal" id="bsqCal">
                      <div class="bsq-cal-head">
                        <span class="bsq-cal-month" id="bsqCalMonth">&nbsp;</span>
                        <span class="bsq-cal-nav">
                          <button type="button" id="bsqPrevMonth" aria-label="Previous month">&lsaquo;</button>
                          <button type="button" id="bsqNextMonth" aria-label="Next month">&rsaquo;</button>
                        </span>
                      </div>
                      <div class="bsq-cal-days" id="bsqCalDays"></div>
                      <div class="bsq-cal-veil" id="bsqCalVeil"><div class="bsq-spin"></div></div>
                    </div>
                  </div>
                  <div>
                    <div class="bsq-cal-cap" id="bsqSlotsCap">Pick a date first</div>
                    <div class="bsq-slots" id="bsqSlots">
                      <div class="bsq-cal-note">Select a highlighted day to see open times.</div>
                    </div>
                  </div>
                </div>

                <div class="bsq-actions">
                  <button type="button" class="bsq-back" id="bsqCallBack">&larr; Back</button>
                  <button type="button" class="bsq-cta" id="bsqConfirmCall" disabled>Confirm my call &rarr;</button>
                </div>
                <div class="bsq-micro">Free &middot; 30 min &middot; reschedule anytime</div>
              </div>
            </div>

            <!-- ============ SCREEN 3B — MATCH ME NOW ============ -->
            <div class="bsq-screen" id="scQuiz">
              <div class="bsq-rail">
                <div class="bsq-ticks"><i></i></div>
                <div class="bsq-rail-eyebrow">Two minutes, tops</div>
                <h3>A few questions to find your fit.</h3>
                <p>A few quick questions about what you&rsquo;re facing and how you like to work &mdash; so we match you with a therapist who specializes in your concerns and fits your schedule, your style, and your life.</p>
                <div class="bsq-testi">
                  <div class="bsq-testi-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
                  <blockquote>&ldquo;I felt very seen, understood, and supported &mdash; Brooke went right to the source of the issue while staying so gentle and kind.&rdquo;</blockquote>
                  <cite>&mdash; J.R., Brentwood</cite>
                </div>
              </div>

              <div class="bsq-field">
                <form id="bsqQuizForm" novalidate>

                  <!-- Q1 -->
                  <div class="bsq-q on" data-q="1">
                    <div class="bsq-qmark">Question 1 of 6</div>
                    <h3>What matters most to you in a therapist?</h3>
                    <p class="bsq-lede">Choose any that resonate &mdash; it helps us pair you with the right person.</p>
                    <div class="bsq-choices" data-group="therapistFit">
                      <label class="bsq-choice"><input type="checkbox" value="Someone who gently challenges me"><span class="bsq-choice-box">&#10003;</span><span><b>Someone who gently challenges me</b><em>Insight plus accountability &mdash; not just a sounding board.</em></span></label>
                      <label class="bsq-choice"><input type="checkbox" value="A warm, steady presence"><span class="bsq-choice-box">&#10003;</span><span><b>A warm, steady presence</b><em>Feeling safe and unhurried matters most right now.</em></span></label>
                      <label class="bsq-choice"><input type="checkbox" value="Deep expertise in what I'm facing"><span class="bsq-choice-box">&#10003;</span><span><b>Deep expertise in what I&rsquo;m facing</b><em>Specialized training in my specific concern.</em></span></label>
                      <label class="bsq-choice"><input type="checkbox" value="Practical tools & between-session work"><span class="bsq-choice-box">&#10003;</span><span><b>Practical tools &amp; between-session work</b><em>Homework, frameworks, things to try in real life.</em></span></label>
                      <label class="bsq-choice"><input type="checkbox" value="Shared identity or lived experience"><span class="bsq-choice-box">&#10003;</span><span><b>Shared identity or lived experience</b><em>Someone who gets my background without explaining.</em></span></label>
                    </div>
                  </div>

                  <!-- Q2 -->
                  <div class="bsq-q" data-q="2">
                    <div class="bsq-qmark">Question 2 of 6</div>
                    <h3>What do you most need support with?</h3>
                    <p class="bsq-lede">Pick any that apply, then tell us how ready you feel.</p>
                    <div class="bsq-pills c3" data-group="support">
                      <label class="bsq-pill"><input type="checkbox" value="Anxiety">Anxiety</label>
                      <label class="bsq-pill"><input type="checkbox" value="Depression">Depression</label>
                      <label class="bsq-pill"><input type="checkbox" value="Trauma">Trauma</label>
                      <label class="bsq-pill"><input type="checkbox" value="Communication issues">Communication</label>
                      <label class="bsq-pill"><input type="checkbox" value="Couples Counseling">Couples</label>
                      <label class="bsq-pill"><input type="checkbox" value="Grief and Loss">Grief and loss</label>
                      <label class="bsq-pill"><input type="checkbox" value="Anger management">Anger</label>
                      <label class="bsq-pill"><input type="checkbox" value="Self-esteem">Self-esteem</label>
                      <label class="bsq-pill"><input type="checkbox" value="Other">Other</label>
                    </div>
                    <div class="bsq-likert">
                      <div class="bsq-group-label">How motivated do you feel to work on this?</div>
                      <div class="bsq-scale" data-scale="motivation">
                        <label><input type="radio" name="motivation" value="0"><span>0</span></label>
                        <label><input type="radio" name="motivation" value="1"><span>1</span></label>
                        <label><input type="radio" name="motivation" value="2"><span>2</span></label>
                        <label><input type="radio" name="motivation" value="3"><span>3</span></label>
                        <label><input type="radio" name="motivation" value="4"><span>4</span></label>
                        <label><input type="radio" name="motivation" value="5"><span>5</span></label>
                        <label><input type="radio" name="motivation" value="6"><span>6</span></label>
                        <label><input type="radio" name="motivation" value="7"><span>7</span></label>
                        <label><input type="radio" name="motivation" value="8"><span>8</span></label>
                        <label><input type="radio" name="motivation" value="9"><span>9</span></label>
                        <label><input type="radio" name="motivation" value="10"><span>10</span></label>
                      </div>
                      <div class="bsq-scale-caps"><span>Not at all</span><span>Somewhat</span><span>I&rsquo;m ready for a change</span></div>
                    </div>
                  </div>

                  <!-- Q3 -->
                  <div class="bsq-q" data-q="3">
                    <div class="bsq-qmark">Question 3 of 6</div>
                    <h3>When can you meet?</h3>
                    <p class="bsq-lede">So we only match you with therapists who have room for you.</p>

                    <div class="bsq-group-label">Days you&rsquo;re available</div>
                    <div class="bsq-pills flow" data-group="days">
                      <label class="bsq-pill"><input type="checkbox" value="Sun">Sun</label>
                      <label class="bsq-pill"><input type="checkbox" value="Mon">Mon</label>
                      <label class="bsq-pill"><input type="checkbox" value="Tue">Tue</label>
                      <label class="bsq-pill"><input type="checkbox" value="Wed">Wed</label>
                      <label class="bsq-pill"><input type="checkbox" value="Thu">Thu</label>
                      <label class="bsq-pill"><input type="checkbox" value="Fri">Fri</label>
                      <label class="bsq-pill"><input type="checkbox" value="Sat">Sat</label>
                    </div>

                    <div class="bsq-group-label">Times that work best</div>
                    <div class="bsq-pills c3" data-group="times">
                      <label class="bsq-pill"><input type="checkbox" value="Morning">Morning</label>
                      <label class="bsq-pill"><input type="checkbox" value="Afternoon">Afternoon</label>
                      <label class="bsq-pill"><input type="checkbox" value="Evening">Evening</label>
                    </div>

                    <div class="bsq-group-label">Pronouns <span>(select any)</span></div>
                    <div class="bsq-pills flow" data-group="pronouns">
                      <label class="bsq-pill"><input type="checkbox" value="She/Her">She/Her</label>
                      <label class="bsq-pill"><input type="checkbox" value="He/Him">He/Him</label>
                      <label class="bsq-pill"><input type="checkbox" value="They/Them">They/Them</label>
                      <label class="bsq-pill"><input type="checkbox" value="Other">Other</label>
                    </div>

                    <div class="bsq-row">
                      <div>
                        <label class="bsq-label" for="bsqAge">Age</label>
                        <input type="number" id="bsqAge" name="age" min="0" max="120" placeholder="Your age">
                      </div>
                      <div>
                        <span class="bsq-label">First time in therapy? *</span>
                        <div class="bsq-radios" data-radio="firstTime" style="margin-bottom:0;">
                          <label class="bsq-radio"><input type="radio" name="firstTime" value="Yes">Yes</label>
                          <label class="bsq-radio"><input type="radio" name="firstTime" value="No">No</label>
                        </div>
                      </div>
                    </div>
                    <p class="bsq-err" id="bsqErrFirstTime"></p>
                  </div>

                  <!-- Q4 -->
                  <div class="bsq-q" data-q="4">
                    <div class="bsq-qmark">Question 4 of 6</div>
                    <h3>What would you like to focus on?</h3>
                    <p class="bsq-lede">Then just two more &mdash; and we start hand-picking your therapist.</p>
                    <div class="bsq-pills c3" data-group="focus">
                      <label class="bsq-pill"><input type="checkbox" value="Increased quality of life">Quality of life</label>
                      <label class="bsq-pill"><input type="checkbox" value="Healthier relationships">Healthier relationships</label>
                      <label class="bsq-pill"><input type="checkbox" value="Feeling proud about myself">Feeling proud of myself</label>
                      <label class="bsq-pill"><input type="checkbox" value="Learning new ways to communicate">Better communication</label>
                      <label class="bsq-pill"><input type="checkbox" value="Decreasing anxiety">Decreasing anxiety</label>
                      <label class="bsq-pill"><input type="checkbox" value="Improving mood">Improving mood</label>
                      <label class="bsq-pill"><input type="checkbox" value="Feeling confident">Feeling confident</label>
                      <label class="bsq-pill"><input type="checkbox" value="Setting healthy boundaries">Healthy boundaries</label>
                      <label class="bsq-pill"><input type="checkbox" value="Learning new ways to manage feelings">Managing feelings</label>
                    </div>

                    <div class="bsq-row one">
                      <div>
                        <label class="bsq-label" for="bsqDetails">Tell us more about what you need support with <span style="font-weight:400;color:var(--muted);font-style:italic;">(optional)</span></label>
                        <textarea id="bsqDetails" name="details" placeholder="Share as much or as little as you'd like&hellip;"></textarea>
                      </div>
                    </div>

                    <div class="bsq-group-label">Should we email or call you back? *</div>
                    <div class="bsq-radios" data-radio="contactMethod">
                      <label class="bsq-radio"><input type="radio" name="contactMethod" value="Email">Email</label>
                      <label class="bsq-radio"><input type="radio" name="contactMethod" value="Call">Call</label>
                    </div>
                    <p class="bsq-err" id="bsqErrContact"></p>
                  </div>

                  <!-- Q5 — CLINICAL SCREENING -->
                  <div class="bsq-q" data-q="5">
                    <div class="bsq-qmark">Question 5 of 6</div>
                    <h3>Do any of these feel true for you &mdash; now or at any point in the past?</h3>
                    <p class="bsq-lede">Check any that apply. This stays confidential &mdash; it only helps us match you with someone properly trained for it. There are no wrong answers here.</p>

                    <div class="bsq-choices tight" data-group="clinicalFlags" id="bsqFlags">
                      <label class="bsq-choice">
                        <input type="checkbox" value="My relationship with alcohol or other substances has been hard to manage" data-short="alcohol or other substances have been hard to manage">
                        <span class="bsq-choice-box">&#10003;</span>
                        <span><b>My relationship with alcohol or other substances has been hard to manage</b></span>
                      </label>
                      <label class="bsq-choice">
                        <input type="checkbox" value="I've hurt myself on purpose" data-short="hurting yourself on purpose">
                        <span class="bsq-choice-box">&#10003;</span>
                        <span><b>I&rsquo;ve hurt myself on purpose</b></span>
                      </label>
                      <label class="bsq-choice">
                        <input type="checkbox" value="I've had experiences other people didn't seem to share — like hearing or seeing things others couldn't" data-short="experiences others didn&rsquo;t seem to share">
                        <span class="bsq-choice-box">&#10003;</span>
                        <span><b>I&rsquo;ve had experiences other people didn&rsquo;t seem to share &mdash; like hearing or seeing things others couldn&rsquo;t</b></span>
                      </label>
                      <label class="bsq-choice">
                        <input type="checkbox" value="There have been times when anger or conflict led to someone getting hurt, or to legal trouble" data-short="anger or conflict leading to harm or legal trouble">
                        <span class="bsq-choice-box">&#10003;</span>
                        <span><b>There have been times when anger or conflict led to someone getting hurt, or to legal trouble</b></span>
                      </label>
                      <label class="bsq-choice">
                        <input type="checkbox" value="I've contacted someone after they asked me not to, or kept track of where they are without them knowing" data-short="contacting or tracking someone who didn&rsquo;t want it">
                        <span class="bsq-choice-box">&#10003;</span>
                        <span><b>I&rsquo;ve contacted someone after they asked me not to, or kept track of where they are without them knowing</b></span>
                      </label>
                      <label class="bsq-choice">
                        <input type="checkbox" value="None of these apply" data-none="1">
                        <span class="bsq-choice-box">&#10003;</span>
                        <span><b>None of these apply</b></span>
                      </label>
                    </div>

                    <div id="bsqFlagFollowups"></div>
                    <p class="bsq-err standalone" id="bsqErrFlags"></p>
                  </div>

                  <!-- Q6 — SUICIDALITY HISTORY -->
                  <div class="bsq-q" data-q="6">
                    <div class="bsq-qmark">Question 6 of 6</div>
                    <h3>Have you ever come close to acting on thoughts of ending your life &mdash; making a plan, or taking steps toward it?</h3>
                    <p class="bsq-lede">We ask everyone. Answering honestly doesn&rsquo;t disqualify you from anything &mdash; it just makes sure the therapist we pick is the right fit.</p>

                    <div class="bsq-choices tight" id="bsqRisk">
                      <label class="bsq-choice">
                        <input type="radio" name="riskHistory" value="No" data-none="1">
                        <span class="bsq-choice-box round">&#10003;</span>
                        <span><b>No</b></span>
                      </label>
                      <label class="bsq-choice">
                        <input type="radio" name="riskHistory" value="Yes, but more than a year ago" data-short="this happened more than a year ago">
                        <span class="bsq-choice-box round">&#10003;</span>
                        <span><b>Yes, but more than a year ago</b></span>
                      </label>
                      <label class="bsq-choice">
                        <input type="radio" name="riskHistory" value="Yes, within the past year" data-short="this happened within the past year">
                        <span class="bsq-choice-box round">&#10003;</span>
                        <span><b>Yes, within the past year</b></span>
                      </label>
                      <label class="bsq-choice">
