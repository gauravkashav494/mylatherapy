.bsq :focus-visible{ outline:2px solid var(--terracotta); outline-offset:2px; }
</style>

<script is:inline>
(function(){
  'use strict';

  /* Backend wiring — Astro API routes replace WP admin-ajax.php. */
  var BSQ = {
    submit: '/api/quiz-submit',
    slots:  '/api/free-slots',
    book:   '/api/book-appointment',
    tz:     'America/Los_Angeles',   // updated from the free-slots response
    backend: true
  };

  var root = document.getElementById('bsqApp');
  if(!root) return;

  var $  = function(id){ return document.getElementById(id); };
  var $$ = function(sel, ctx){ return Array.prototype.slice.call((ctx||root).querySelectorAll(sel)); };
  var esc = function(s){ var d = document.createElement('div'); d.textContent = s; return d.innerHTML; };

  var screens = {
    capture: $('scCapture'),
    path:    $('scPath'),
    call:    $('scCall'),
    quiz:    $('scQuiz'),
    done:    $('scDone')
  };

  var state = {
    matchMethod: null,
    leadCaptured: false,
    leadCapturedAt: 0,
    quizIndex: 0,
    slot: null,
    appointmentId: ''
  };

  var quizCards = $$('.bsq-q', screens.quiz);

  /* Toggles — pills, checkbox choice cards, radio pills */
  $$('.bsq-pill').forEach(function(el){
    var input = el.querySelector('input');
    el.addEventListener('click', function(){
      setTimeout(function(){ el.classList.toggle('on', input.checked); }, 0);
    });
  });

  $$('.bsq-choice').forEach(function(el){
    var input = el.querySelector('input');
    if(!input || input.type !== 'checkbox') return;
    el.addEventListener('click', function(){
      setTimeout(function(){ el.classList.toggle('on', input.checked); }, 0);
    });
  });

  $$('.bsq-radios').forEach(function(row){
    row.addEventListener('change', function(){
      $$('.bsq-radio', row).forEach(function(r){
        r.classList.toggle('on', r.querySelector('input').checked);
      });
      hideErr(row.parentNode.querySelector('.bsq-err'));
    });
  });

  /* Errors */
  function showErr(el, msg){ if(el){ el.textContent = msg; el.classList.add('show'); } }
  function hideErr(el){ if(el) el.classList.remove('show'); }
  function note(msg){
    var n = $('bsqCalNote');
    if(!msg){ n.classList.remove('show'); return; }
    n.textContent = msg; n.classList.add('show');
  }

  /* Follow-up blocks (Q5 / Q6) */
  function buildFollowup(fullValue, shortLabel){
    var d = document.createElement('div');
    d.className = 'bsq-followup';
    d.dataset.for = fullValue;
    d.innerHTML =
      '<div class="bsq-followup-q">You checked <i>' + shortLabel + '</i>. ' +
        'Tell us a bit more &mdash; a sentence or two is plenty.</div>' +
      '<textarea class="bsq-followup-text" rows="2" placeholder="A sentence or two is plenty&hellip;"></textarea>' +
      '<label class="bsq-check">' +
        '<input type="checkbox" class="bsq-followup-skip">' +
        '<span class="bsq-check-box">&#10003;</span>' +
        '<span>I&rsquo;d rather talk about this on the call</span>' +
      '</label>';

    var skip = d.querySelector('.bsq-followup-skip');
    var text = d.querySelector('.bsq-followup-text');
    var lab  = d.querySelector('.bsq-check');
    skip.addEventListener('change', function(){
      lab.classList.toggle('on', skip.checked);
      text.disabled = skip.checked;
      if(skip.checked) text.value = '';
    });
    return d;
  }

  function collectFollowups(wrap){
    return $$('.bsq-followup', wrap).map(function(d){
      var skip = d.querySelector('.bsq-followup-skip').checked;
      var txt  = d.querySelector('.bsq-followup-text').value.trim();
      var note = skip ? 'Prefers to discuss on the call'
                      : (txt || 'No detail given');
      return d.dataset.for + ' — ' + note;
    }).join('  |  ');
  }

  /* Q5 */
  var flagBox  = $('bsqFlags');
  var flagWrap = $('bsqFlagFollowups');

  function flagInputs(){ return $$('input[type=checkbox]', flagBox); }

  function renderFlagFollowups(){
    var picked = flagInputs().filter(function(i){ return i.checked && !i.dataset.none; });
    var want   = picked.map(function(i){ return i.value; });

    $$('.bsq-followup', flagWrap).forEach(function(d){
      if(want.indexOf(d.dataset.for) === -1) d.remove();
    });

    picked.forEach(function(i){
      var exists = $$('.bsq-followup', flagWrap).some(function(d){ return d.dataset.for === i.value; });
      if(!exists) flagWrap.appendChild(buildFollowup(i.value, i.dataset.short || i.value));
    });
  }

  flagBox.addEventListener('change', function(e){
    var input = e.target;
    if(input.type !== 'checkbox') return;

    if(input.dataset.none && input.checked){
      flagInputs().forEach(function(i){
        if(i === input) return;
        i.checked = false;
        i.closest('.bsq-choice').classList.remove('on');
      });
    } else if(input.checked){
      var none = flagBox.querySelector('input[data-none]');
      if(none && none.checked){
        none.checked = false;
        none.closest('.bsq-choice').classList.remove('on');
      }
    }
    renderFlagFollowups();
    hideErr($('bsqErrFlags'));
  });

  /* Q6 */
  var riskBox  = $('bsqRisk');
  var riskWrap = $('bsqRiskFollowup');

  riskBox.addEventListener('change', function(e){
    var input = e.target;
    if(input.type !== 'radio') return;

    $$('.bsq-choice', riskBox).forEach(function(c){
      c.classList.toggle('on', c.querySelector('input').checked);
    });

    riskWrap.innerHTML = '';
    $('bsqCrisis').classList.toggle('show', !!input.dataset.urgent);

    if(!input.dataset.none){
      riskWrap.appendChild(buildFollowup(input.value, input.dataset.short || input.value));
    }
    hideErr($('bsqErrRisk'));
  });

  /* Payload */
  function groupValues(group){
    return $$('[data-group="'+group+'"] input:checked').map(function(i){ return i.value; }).join(', ');
  }
  function radioValue(name){
    var el = root.querySelector('input[name="'+name+'"]:checked');
    return el ? el.value : '';
  }
  function buildPayload(stage){
    var motivation = radioValue('motivation');
    return {
      stage:          stage,
      matchMethod:    state.matchMethod || '',
      pageUrl:        window.location.href,
      firstName:      $('bsqFirst').value.trim(),
      lastName:       '',
      email:          $('bsqEmail').value.trim(),
      concerns:       groupValues('concerns'),
      location:       $('bsqLocation').value,
      therapistFit:   groupValues('therapistFit'),
      pronouns:       groupValues('pronouns'),
      age:            $('bsqAge').value ? Number($('bsqAge').value) : null,
      days:           groupValues('days'),
      times:          groupValues('times'),
      firstTime:      radioValue('firstTime'),
      supportNeeds:   groupValues('support'),
      motivation:     motivation !== '' ? Number(motivation) : null,
      focus:          groupValues('focus'),
      details:        $('bsqDetails').value.trim(),
      contactMethod:  radioValue('contactMethod'),
      clinicalFlags:   groupValues('clinicalFlags'),
      clinicalDetails: collectFollowups(flagWrap),
      riskHistory:     radioValue('riskHistory'),
      riskDetails:     collectFollowups(riskWrap),
      slot:           state.slot || '',
      appointmentId:  state.appointmentId || '',
      submittedAt:    new Date().toISOString()
    };
  }

  function post(url, fields){
    return fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify(fields)
    }).then(function(r){ return r.json().catch(function(){ return { success:false }; }); });
  }

  function sendProgress(){
    var payload = buildPayload('lead_capture');
    payload.capturedAt = new Date().toISOString();
    if(!payload.email) return Promise.resolve();

    if(!state.leadCaptured){ state.leadCaptured = true; state.leadCapturedAt = Date.now(); }
    window.lastLeadPayload = payload;

    return post(BSQ.submit, { step:'partial', payload: JSON.stringify(payload) })
      .catch(function(err){ console.error('[BSQ2] progress sync failed', err); });
  }

  function sendComplete(){
    var payload = buildPayload('quiz_complete');
    window.lastQuizPayload = payload;
    var within = state.leadCapturedAt && (Date.now() - state.leadCapturedAt) <= 5 * 60 * 1000;
    return post(BSQ.submit, {
      step:     'complete',
      payload:  JSON.stringify(payload),
      isUpdate: (within && state.leadCaptured) ? 'true' : 'false'
    }).catch(function(err){ console.error('[BSQ2] submit failed', err); });
  }

  /* Screens */
  function show(name){
    Object.keys(screens).forEach(function(k){ screens[k].classList.toggle('on', k === name); });
    var top = root.getBoundingClientRect().top + window.pageYOffset - 24;
    if(window.pageYOffset > top) window.scrollTo({ top: top, behavior: 'smooth' });
  }
  function setName(){
    var n = $('bsqFirst').value.trim() || 'there';
    $$('.bsq-name').forEach(function(el){ el.textContent = n; });
  }

  /* Screen 1: capture */
  function validateCapture(){
    var first = $('bsqFirst'), email = $('bsqEmail');
    var ok = true, msgs = [];

    [first, email].forEach(function(i){ i.classList.remove('invalid'); });
    hideErr($('bsqErrCapture')); hideErr($('bsqErrConcerns'));

    if(!first.value.trim()){
      first.classList.add('invalid');
      msgs.push('Enter your first name.');
      ok = false;
    }
    if(!email.value.trim() || !email.checkValidity()){
      email.classList.add('invalid');
      msgs.push('Enter a valid email — that’s where your match goes.');
      ok = false;
    }
    if(msgs.length) showErr($('bsqErrCapture'), msgs.join(' '));

    if(!groupValues('concerns')){
      showErr($('bsqErrConcerns'), 'Pick at least one — it tells us who to look for.');
      ok = false;
    }
    if(!ok){
      var bad = root.querySelector('.invalid');
      if(bad) bad.focus();
    }
    return ok;
  }

  $('bsqCaptureNext').addEventListener('click', function(){
    if(!validateCapture()) return;
    setName();
    sendProgress();
    show('path');
  });
  root.addEventListener('input', function(e){
    if(e.target.matches('input, textarea')) e.target.classList.remove('invalid');
  });

  /* Screen 2: path fork */
  $$('.bsq-path').forEach(function(btn){
    btn.addEventListener('click', function(){ choosePath(btn.dataset.path); });
  });
  $('bsqStartCall').addEventListener('click', function(){ choosePath('call'); });
  $('bsqDoneBookCall').addEventListener('click', function(){ choosePath('call'); });

  function choosePath(path){
    state.matchMethod = path;
    sendProgress();
    if(path === 'call'){
      show('call');
      initCalendar();
    } else {
      state.quizIndex = 0;
      renderQuiz();
      show('quiz');
    }
  }

  /* Screen 3B — quiz */
  function renderQuiz(){
    quizCards.forEach(function(c, i){ c.classList.toggle('on', i === state.quizIndex); });
    $('bsqQuizNext').textContent = state.quizIndex === quizCards.length - 1 ? 'Get my match →' : 'Continue →';
  }

  function validateQuiz(){
    if(state.quizIndex === 2 && !radioValue('firstTime')){
      showErr($('bsqErrFirstTime'), 'Let us know if this is your first time in therapy.');
      return false;
    }
    if(state.quizIndex === 3 && !radioValue('contactMethod')){
      showErr($('bsqErrContact'), 'Choose how we should follow up with you.');
      return false;
    }
    if(state.quizIndex === 4 && !groupValues('clinicalFlags')){
      showErr($('bsqErrFlags'), 'Pick any that apply — or choose “None of these apply” to move on.');
      return false;
    }
    if(state.quizIndex === 5 && !radioValue('riskHistory')){
      showErr($('bsqErrRisk'), 'Choose the answer that fits best — whatever it is, it won’t count against you.');
      return false;
    }
    return true;
  }

  $('bsqQuizForm').addEventListener('submit', function(e){
    e.preventDefault();
    if(!validateQuiz()) return;
    if(state.quizIndex < quizCards.length - 1){
      sendProgress();
      state.quizIndex++;
      renderQuiz();
      return;
    }
    sendComplete();
    setName();
    $('bsqDoneRailH').innerHTML = 'We&rsquo;re finding your match.';
    $('bsqDoneRailP').textContent = 'A real person on our team is reviewing your details now and will hand-select the right therapist for you — usually within 24–48 hours.';
    $('bsqDoneP').textContent = 'We’ve got everything we need. Keep an eye on your inbox — we’ll email you as soon as your match is ready.';
    $('bsqDoneAlt').style.display = '';
    show('done');
  });
  $('bsqQuizBack').addEventListener('click', function(){
    if(state.quizIndex === 0){ show('path'); return; }
    state.quizIndex--;
    renderQuiz();
  });

  /* Screen 3A — calendar */
  var cal = {
    view: null, min: null, slots: {}, loadedMonths: {}, date: null, started: false
  };
  var MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];

  function ym(d){ return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0'); }
  function iso(y, m, d){ return y + '-' + String(m+1).padStart(2,'0') + '-' + String(d).padStart(2,'0'); }

  function initCalendar(){
    if(cal.started) return;
    cal.started = true;
    if(!BSQ.backend){
      $('bsqCalVeil').style.display = 'none';
      note('The calendar isn’t connected yet. Choose "Match me now" and we’ll reach out instead.');
      return;
    }
    var now = new Date();
    cal.min  = new Date(now.getFullYear(), now.getMonth(), 1);
    cal.view = new Date(now.getFullYear(), now.getMonth(), 1);
    loadMonth(cal.view);
  }

  function loadMonth(viewDate){
    var key = ym(viewDate);
    renderCalendar();
    if(cal.loadedMonths[key]){ return Promise.resolve(); }
    $('bsqCalVeil').style.display = 'flex';

    return post(BSQ.slots, { month: key, timezone: BSQ.tz })
      .then(function(res){
        $('bsqCalVeil').style.display = 'none';
        if(!res || !res.success){
          note((res && res.data && res.data.message) || 'We couldn’t load open times just now. Refresh the page, or choose "Match me now" and we’ll reach out.');
          return;
        }
        note('');
        if(res.data.timezone) BSQ.tz = res.data.timezone;
        cal.loadedMonths[key] = true;
        Object.keys(res.data.dates || {}).forEach(function(d){ cal.slots[d] = res.data.dates[d]; });
        renderCalendar();
      })
      .catch(function(err){
        $('bsqCalVeil').style.display = 'none';
        console.error('[BSQ2] free-slots failed', err);
        note('We couldn’t load open times just now. Refresh the page, or choose "Match me now" and we’ll reach out.');
      });
  }

  function renderCalendar(){
    var y = cal.view.getFullYear(), m = cal.view.getMonth();
    $('bsqCalMonth').textContent = MONTHS[m] + ' ' + y;
    $('bsqPrevMonth').disabled = (y === cal.min.getFullYear() && m === cal.min.getMonth());

    var wrap = $('bsqCalDays');
    wrap.innerHTML = '';
    ['S','M','T','W','T','F','S'].forEach(function(d){
      var el = document.createElement('div');
      el.className = 'bsq-dow'; el.textContent = d;
      wrap.appendChild(el);
    });

    var lead = new Date(y, m, 1).getDay();
    for(var i = 0; i < lead; i++) wrap.appendChild(document.createElement('div'));

    var total = new Date(y, m + 1, 0).getDate();
    for(var d = 1; d <= total; d++){
      var key = iso(y, m, d);
      var el  = document.createElement('div');
      el.className = 'bsq-day';
      el.textContent = d;
      if(cal.slots[key] && cal.slots[key].length){
        el.classList.add('open');
        el.dataset.date = key;
        el.setAttribute('role','button');
        el.setAttribute('tabindex','0');
        if(cal.date === key) el.classList.add('on');
        el.addEventListener('click', function(){ pickDate(this.dataset.date); });
        el.addEventListener('keydown', function(e){
          if(e.key === 'Enter' || e.key === ' '){ e.preventDefault(); pickDate(this.dataset.date); }
        });
      }
      wrap.appendChild(el);
    }
  }

  function fmtTime(isoStr){
    var d = new Date(isoStr);
    return d.toLocaleTimeString('en-US', { hour:'numeric', minute:'2-digit', timeZone: BSQ.tz });
  }
  function fmtDay(key){
    var p = key.split('-');
    var d = new Date(Number(p[0]), Number(p[1]) - 1, Number(p[2]));
    return d.toLocaleDateString('en-US', { weekday:'short', month:'short', day:'numeric' });
  }
  function tzAbbr(){
    try{
      return new Intl.DateTimeFormat('en-US', { timeZone: BSQ.tz, timeZoneName:'short' })
        .formatToParts(new Date()).find(function(p){ return p.type === 'timeZoneName'; }).value;
    }catch(e){ return ''; }
  }

  function pickDate(key){
    cal.date  = key;
    state.slot = null;
    $('bsqConfirmCall').disabled = true;
    renderCalendar();

    $('bsqSlotsCap').textContent = fmtDay(key) + ' · ' + tzAbbr();
    var box = $('bsqSlots');
    box.innerHTML = '';
    (cal.slots[key] || []).forEach(function(slot){
      var b = document.createElement('button');
      b.type = 'button';
      b.className = 'bsq-slot';
      b.textContent = fmtTime(slot);
      b.dataset.slot = slot;
      b.addEventListener('click', function(){
        $$('.bsq-slot').forEach(function(s){ s.classList.remove('on'); });
        b.classList.add('on');
        state.slot = slot;
        $('bsqConfirmCall').disabled = false;
      });
      box.appendChild(b);
    });
  }

  $('bsqPrevMonth').addEventListener('click', function(){
    if(this.disabled) return;
    cal.view = new Date(cal.view.getFullYear(), cal.view.getMonth() - 1, 1);
    loadMonth(cal.view);
  });
  $('bsqNextMonth').addEventListener('click', function(){
    cal.view = new Date(cal.view.getFullYear(), cal.view.getMonth() + 1, 1);
    loadMonth(cal.view);
  });
  $('bsqCallBack').addEventListener('click', function(){ show('path'); });

  $('bsqConfirmCall').addEventListener('click', function(){
    if(!state.slot) return;
    var btn = this;
    btn.disabled = true;
    btn.textContent = 'Booking…';
    note('');

    post(BSQ.book, {
      slot:      state.slot,
      timezone:  BSQ.tz,
      payload:   JSON.stringify(buildPayload('call_booked'))
    }).then(function(res){
      if(!res || !res.success){
        btn.disabled = false;
        btn.textContent = 'Confirm my call →';
        note((res && res.data && res.data.message) || 'That time was just taken. Pick another and we’ll lock it in.');
        delete cal.loadedMonths[ym(cal.view)];
        loadMonth(cal.view);
        return;
      }
      state.appointmentId = res.data.appointmentId || '';
      setName();
      var when = fmtDay(cal.date) + ' at ' + fmtTime(state.slot) + ' ' + tzAbbr();
      $('bsqDoneRailH').innerHTML = 'Your call is booked.';
      $('bsqDoneRailP').textContent = 'We’ll come to the call already knowing your details — and you’ll leave it matched.';
      $('bsqDoneH').innerHTML = 'You’re on the calendar, <span class="bsq-name">' + esc($('bsqFirst').value.trim() || 'there') + '</span>.';
      $('bsqDoneP').textContent = when + '. A confirmation is on its way to ' + $('bsqEmail').value.trim() + '.';
      $('bsqDoneAlt').style.display = 'none';
      show('done');
    }).catch(function(err){
      console.error('[BSQ2] booking failed', err);
      btn.disabled = false;
      btn.textContent = 'Confirm my call →';
      note('The booking didn’t go through. Try again, or choose "Match me now" and we’ll reach out.');
    });
  });

})();
</script>
