---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.tsx';
import Footer from '../components/Footer.astro';
import MatchCta from '../components/MatchCta.astro';

// Neighborhood image tiles — each with a true-to-place vibe read + nearby areas.
const hoods = [
  { name: 'Santa Monica', img: 'office-santa-monica.png', tag: 'Silicon Beach & Venice', line: "Founders, coastal wellness, and the quiet pressure of the beach city that's supposed to have it all together.", near: ['Venice', 'Pacific Palisades', 'Mar Vista', 'Rustic Canyon'] },
  { name: 'West LA', img: 'office-west-la.png', tag: 'Westside ease', line: 'Brentwood-adjacent professionals and families who keep it low-key and want depth without the fuss.', near: ['Brentwood', 'Westwood', 'Century City', 'Sawtelle'] },
  { name: 'Beverly Hills', img: 'office-beverly-hills.png', tag: 'Discretion & prestige', line: 'Executives and public figures who need somewhere completely private to just be a person.', near: ['Bel-Air', 'West Hollywood', 'Hancock Park', 'Beverly Crest'] },
  { name: 'Encino', img: 'office-encino.png', tag: 'The Valley calm', line: 'Valley families and industry folks who want something real, close to home.', near: ['Sherman Oaks', 'Calabasas', 'Woodland Hills', 'Hidden Hills'] },
  { name: 'Studio City', img: 'office-studio-city.png', tag: 'Industry Executives', line: 'Writers, creatives, and the entertainment world — therapy that gets both the business and the art.', near: ['Toluca Lake', 'Burbank', 'Hollywood Hills', 'Universal City'] },
  { name: 'Pasadena', img: 'office-pasadena.png', tag: 'Rooted & established', line: 'Academics, families, and a slower, more considered pace east of the city.', near: ['Glendale', 'South Pasadena', 'Highland Park', 'San Marino'] },
  { name: 'Echo Park', img: 'office-echo-park.png', tag: 'Eastside & independent', line: 'Artists and young creatives building something on their own anti-corporate terms.', near: ['Silver Lake', 'Los Feliz', 'DTLA', 'Koreatown'] },
];

const regions = ['Westside', 'Beverly Hills', 'The Valley', 'Eastside', 'Pasadena'];

// Structured data: the practice + each in-person office as a place we serve.
const SITE = 'https://mylatherapy.com';
const locationsJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MedicalBusiness',
  '@id': `${SITE}/#organization`,
  name: 'My LA Therapy',
  url: `${SITE}/locations`,
  areaServed: [
    ...hoods.map((h) => ({ '@type': 'Place', name: `${h.name}, Los Angeles, CA` })),
    { '@type': 'State', name: 'California' },
  ],
};
---
<Layout title="Therapy Locations Across Los Angeles | My LA Therapy" description="In-person therapy across seven LA neighborhoods — Santa Monica, West LA, Beverly Hills, Encino, Studio City, Pasadena, and Echo Park — plus online therapy anywhere in California." path="/locations" image="/images/office-santa-monica.png">
  <div id="top">
    <Nav client:load />
    <main style="background:var(--cream);">

        <!-- FOREST HERO -->
        <section id="s-hero" style="background:var(--forest);color:var(--cream-text);padding:52px 24px 46px;">
         <div class="wrap split loc-hero" style="display:grid;grid-template-columns:1.15fr .85fr;gap:44px;align-items:center;">
          <div>
            <div style="font-size:13px;letter-spacing:.14em;text-transform:uppercase;color:var(--sage);font-weight:600;margin-bottom:16px;">In-person therapy across LA</div>
            <h1 class="h1-fluid" style="font-family:var(--serif);font-weight:500;font-size:50px;line-height:1.06;letter-spacing:-.02em;margin:0 0 18px;color:var(--white);">Seven offices. One <span style="font-style:italic;color:var(--tan);">exceptionally high</span> bar.</h1>
            <p style="font-size:17.5px;line-height:1.6;color:var(--sage-pale);margin:0 0 26px;max-width:520px;">Other LA therapy networks are owned by tech companies, matching you by algorithm. We're a boutique practice where every therapist — in every neighborhood — is personally vetted and trained by our founder.</p>
            <div style="display:flex;gap:12px;flex-wrap:wrap;">
              <a href="#map" style="text-decoration:none;background:var(--terracotta);color:var(--white);font-weight:600;font-size:15.5px;padding:14px 26px;border-radius:999px;">Find your neighborhood</a>
              <a href="#book" style="text-decoration:none;background:rgba(255,255,255,.1);color:var(--white);font-weight:600;font-size:15.5px;padding:14px 24px;border-radius:999px;border:1px solid rgba(255,255,255,.25);">Prefer online?</a>
            </div>
          </div>
          <div style="aspect-ratio:1/1;border-radius:18px;overflow:hidden;border:1px solid rgba(255,255,255,.12);">
            <img src="/images/office-beverly-hills.png" alt="In-person therapy office in Los Angeles" style="width:100%;height:100%;object-fit:cover;display:block;" />
          </div>
         </div>
        </section>

        <!-- NEIGHBORHOOD IMAGE TILES -->
        <section id="map" style="background:var(--cream);padding:50px 24px 56px;">
          <div style="text-align:center;max-width:820px;margin:0 auto 30px;">
            <h2 class="h2-fluid" style="font-family:var(--serif);font-weight:500;font-size:38px;line-height:1.08;letter-spacing:-.01em;margin:0 0 4px;color:var(--forest-ink);">In-person therapy, <span style="font-style:italic;color:var(--terracotta);">in your neighborhood.</span></h2>
            <div style="display:flex;align-items:center;justify-content:center;flex-wrap:wrap;gap:0;margin-top:20px;">
              {regions.map((r, i) => (
                <>
                  {i > 0 && <span style="width:1px;height:20px;background:var(--border-5);flex:none;margin:0 2px;"></span>}
                  <a href="#map" style="text-decoration:none;display:inline-flex;align-items:center;gap:7px;padding:4px 16px;font-family:var(--serif);font-size:20px;font-weight:500;color:var(--forest-ink);white-space:nowrap;">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--terracotta)" stroke-width="2.2" style="flex:none;"><path d="M21 10c0 6-9 12-9 12s-9-6-9-12a9 9 0 0118 0z"></path><circle cx="12" cy="10" r="2.6"></circle></svg>{r}
                  </a>
                </>
              ))}
            </div>
          </div>

          <div class="grid-hoods" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px;max-width:1180px;margin:0 auto;">
            {hoods.map((h) => (
              <a href="#book" class="loc-card" style="text-decoration:none;color:inherit;background:var(--white);border:1px solid var(--border);border-radius:18px;overflow:hidden;display:flex;flex-direction:column;box-shadow:0 1px 3px rgba(33,58,48,.05);">
                <div style="position:relative;height:152px;overflow:hidden;">
                  <img src={`/images/${h.img}`} alt={`${h.name} in-person therapy office in Los Angeles`} width="380" height="152" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" />
                  <span style="position:absolute;left:14px;bottom:12px;background:rgba(33,58,48,.82);color:var(--tan);font-size:10.5px;letter-spacing:.1em;text-transform:uppercase;font-weight:700;padding:5px 11px;border-radius:999px;">{h.tag}</span>
                </div>
                <div style="padding:20px 22px 22px;display:flex;flex-direction:column;flex:1;">
                  <h3 style="font-family:var(--serif);font-weight:500;font-size:23px;line-height:1.1;color:var(--forest-ink);margin:0 0 8px;">{h.name}</h3>
                  <p style="font-size:14.5px;line-height:1.55;color:var(--muted);margin:0 0 22px;">{h.line}</p>
                  <div style="border-top:1px solid var(--border-7);padding-top:13px;margin-bottom:15px;">
                    <div style="font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--terracotta);font-weight:700;margin-bottom:9px;">Nearby neighborhoods</div>
                    <div style="display:flex;flex-wrap:wrap;gap:6px;">
                      {h.near.slice(0, 4).map((n) => <span style="font-size:11.5px;color:var(--muted);background:var(--chip-cream);border-radius:999px;padding:4px 11px;">{n}</span>)}
                    </div>
                  </div>
                  <span style="font-size:13.5px;font-weight:600;color:var(--forest);display:inline-flex;align-items:center;gap:5px;margin-top:auto;"><span style="border-bottom:2px solid var(--terracotta);padding-bottom:2px;">{h.name} location</span><span style="color:var(--terracotta);">→</span></span>
                </div>
              </a>
            ))}

            <!-- ONLINE & HYBRID -->
            <a href="#book" class="loc-card" style="text-decoration:none;color:inherit;background:var(--white);border:1px solid var(--border);border-radius:18px;overflow:hidden;display:flex;flex-direction:column;box-shadow:0 1px 3px rgba(33,58,48,.05);">
              <div style="position:relative;height:152px;overflow:hidden;background:var(--forest);display:flex;align-items:center;justify-content:center;">
                <svg width="98" height="98" viewBox="0 0 98 98" fill="none" stroke="var(--terracotta)" style="transform:translateY(-14px);"><circle cx="49" cy="49" r="6" fill="var(--terracotta)" stroke="none"></circle><circle cx="49" cy="49" r="19" stroke-width="1.5"></circle><circle cx="49" cy="49" r="33" stroke-width="1.5"></circle></svg>
                <span style="position:absolute;left:14px;bottom:12px;background:rgba(246,241,233,.18);border:1px solid rgba(231,184,148,.45);color:#F2D9BF;font-size:10.5px;letter-spacing:.1em;text-transform:uppercase;font-weight:700;padding:5px 11px;border-radius:999px;">Anywhere in LA &amp; Cali</span>
              </div>
              <div style="padding:20px 22px 22px;display:flex;flex-direction:column;flex:1;">
                <h3 style="font-family:var(--serif);font-weight:500;font-size:23px;line-height:1.1;color:var(--forest-ink);margin:0 0 8px;">Online &amp; Hybrid</h3>
                <p style="font-size:14.5px;line-height:1.55;color:var(--muted);margin:0 0 22px;">Can't make it in? The same vetted therapists and the same careful match — from your couch, anywhere in California.</p>
                <div style="border-top:1px solid var(--border-7);padding-top:13px;margin-bottom:15px;">
                  <div style="font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--terracotta);font-weight:700;margin-bottom:9px;">Anywhere in Los Angeles &amp; CA</div>
                  <div style="display:flex;flex-wrap:wrap;gap:6px;">
                    <span style="font-size:11.5px;color:var(--muted);background:var(--chip-cream);border-radius:999px;padding:4px 11px;">Secure video</span>
                    <span style="font-size:11.5px;color:var(--muted);background:var(--chip-cream);border-radius:999px;padding:4px 11px;">Evenings &amp; weekends</span>
                  </div>
                </div>
                <span style="font-size:13.5px;font-weight:600;color:var(--forest);display:inline-flex;align-items:center;gap:5px;margin-top:auto;"><span style="border-bottom:2px solid var(--terracotta);padding-bottom:2px;">Match me online</span><span style="color:var(--terracotta);">→</span></span>
              </div>
            </a>
          </div>
        </section>

        <!-- ONLINE BAND -->
        <section style="background:var(--sand-2);padding:52px 24px;text-align:center;">
          <div style="max-width:680px;margin:0 auto;">
            <div style="font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--terracotta);font-weight:700;margin-bottom:12px;">Online therapy</div>
            <h2 style="font-family:var(--serif);font-weight:500;font-size:34px;line-height:1.1;margin:0 0 12px;color:var(--forest-ink);">Can't make it in? <span style="font-style:italic;color:var(--terracotta);">All of California, online.</span></h2>
            <p style="font-size:16.5px;line-height:1.6;color:var(--muted);margin:0 0 22px;">The same vetted therapists and the same careful match — from your couch, between meetings, or anywhere in the state.</p>
            <a href="#book" style="text-decoration:none;display:inline-block;background:var(--forest);color:var(--cream);font-weight:600;font-size:15px;padding:13px 28px;border-radius:999px;">Match me online →</a>
          </div>
        </section>

        <!-- LEAD CAPTURE -->
        <MatchCta
          bg="var(--mist)"
          heading="Find a therapist in LA,"
          accent="close to home."
          text="Your neighborhood, online, or both — and a little about what's going on. We'll match you with the right specialist, usually within 24–48 hours."
          bullets={[
            'In-person across seven LA neighborhoods',
            'Online anywhere in California',
            'First session guaranteed — or we re-match you free',
          ]}
        />

    </main>
    <Footer />
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(locationsJsonLd)} />

  <style>
    .loc-card { transition: box-shadow .18s ease, transform .18s ease; }
    .loc-card:hover { box-shadow: 0 16px 40px -22px rgba(33,58,48,.4); transform: translateY(-2px); }
    @media (max-width: 860px) {
      .loc-hero { grid-template-columns: 1fr !important; }
      .loc-hero > div:last-child { max-width: 420px; }
    }
  </style>
</Layout>
