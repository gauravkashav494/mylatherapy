---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.tsx';
import Footer from '../components/Footer.astro';

// Featured (Popular right now)
const featured = {
  eyebrow: 'Featured · Trauma & the Nervous System',
  title: 'Healing the Nervous System: Combining Sensate with Therapy, Mindfulness & Strength Training',
  excerpt: 'How regulating the nervous system — through somatic work, mindfulness, and the body — turns insight into lasting change.',
  by: 'Brooke Sprowl', date: 'May 27, 2026', read: '9 min read',
  img: 'blog-nervous-system', ext: 'webp',
};

// Numbered topic verticals — each a small set of posts + "view all"
const groups = [
  {
    id: 'anxiety-depression', title: 'Anxiety & Depression', blurb: 'the racing mind and the flat days',
    items: [
      { cat: 'Anxiety', title: 'High-Functioning Anxiety: Looking Fine, Feeling Anything But', excerpt: 'Successful on paper, spinning underneath. Why the most capable people are often the most anxious.', by: 'Brooke Sprowl', date: 'Apr 18, 2026', img: 'blog-anxiety-options', ext: 'webp' },
      { cat: 'Depression', title: 'Depression That Doesn’t Look Like Depression', excerpt: 'Not always sadness — sometimes numbness, irritability, or just going through the motions.', by: 'Brooke Sprowl', date: 'Mar 30, 2026', img: 'blog-depression', ext: 'webp' },
      { cat: 'Anxiety', title: 'The Anxious Mind at 3am: Quieting the Loop', excerpt: 'What the spiraling really is, and a few things that actually settle the nervous system.', by: 'Hailey Hernandez', date: 'Mar 12, 2026', img: 'blog-morning-anxiety', ext: 'webp' },
    ],
  },
  {
    id: 'trauma-ns', title: 'Trauma & the Nervous System', blurb: 'where the body keeps the score',
    items: [
      { cat: 'Nervous System', title: 'Healing the Nervous System: Sensate, Mindfulness & Strength', excerpt: 'How regulating the body turns insight into lasting, embodied change.', by: 'Brooke Sprowl', date: 'May 27, 2026', img: 'blog-nervous-system', ext: 'webp' },
      { cat: 'Trauma & C-PTSD', title: 'What Complex Trauma Actually Does to the Body', excerpt: 'Why developmental trauma shows up as patterns, not just memories.', by: 'Brooke Sprowl', date: 'May 4, 2026', img: 'blog-body-trauma', ext: 'webp' },
      { cat: 'Trauma', title: 'Why Insight Alone Won’t Heal Trauma', excerpt: 'You can understand exactly what happened and still feel it in your body. Here’s why.', by: 'Brooke Sprowl', date: 'Apr 9, 2026', img: 'blog-stuck-trauma', ext: 'webp' },
    ],
  },
  {
    id: 'relationships', title: 'Relationships, Couples & Codependency', blurb: 'the people closest to you',
    items: [
      { cat: 'Relationships', title: 'The Hidden Reason That Keeps Couples Stuck in the Same Fight', excerpt: 'Why the same argument keeps returning in a new costume — and what breaks the loop.', by: 'Brooke Sprowl', date: 'Apr 30, 2026', img: 'blog-couples-stuck', ext: 'webp' },
      { cat: 'Communication', title: 'This Subtle Communication Mistake Might Be Pushing Your Partner Away', excerpt: 'A small habit in how we speak quietly erodes closeness — and the shift that repairs it.', by: 'Brooke Sprowl', date: 'May 13, 2026', img: 'blog-communication', ext: 'webp' },
      { cat: 'Codependency', title: 'Codependency: When Love Becomes Self-Abandonment', excerpt: 'People-pleasing, lost boundaries, and the attachment that tips into losing yourself.', by: 'Brooke Sprowl', date: 'Apr 2, 2026', img: 'blog-emotional-safety', ext: 'webp' },
    ],
  },
  {
    id: 'self-worth', title: 'Self-Worth, Shame & Perfectionism', blurb: 'the inner critic and never-enough',
    items: [
      { cat: 'Self-Worth', title: 'The Inner Critic Isn’t Telling You the Truth', excerpt: 'Where the harsh inner voice comes from, and how to stop taking it as fact.', by: 'Brooke Sprowl', date: 'Mar 22, 2026', img: 'blog-inner-critic', ext: 'webp' },
      { cat: 'Perfectionism', title: 'Perfectionism Is a Protective Strategy, Not a Personality', excerpt: 'What perfectionism is actually defending against — and what it costs to keep it.', by: 'Brooke Sprowl', date: 'Mar 5, 2026', img: 'blog-productivity-trap', ext: 'webp' },
      { cat: 'Shame', title: 'On Shame, and the Parts of Us We Hide', excerpt: 'Shame survives in secrecy. What changes when we bring those parts into the light.', by: 'Brooke Sprowl', date: 'Feb 19, 2026', img: 'blog-shadow-work', ext: 'webp' },
    ],
  },
  {
    id: 'creativity', title: 'Creativity & Performance', blurb: 'for makers and high-achievers',
    items: [
      { cat: 'Creativity', title: 'The Creative Block Is Rarely About Creativity', excerpt: 'What’s usually underneath the block — and how to move with it instead of against it.', by: 'Brooke Sprowl', date: 'Apr 24, 2026', img: 'blog-creative', ext: 'webp' },
      { cat: 'Peak Performance', title: 'High-Performers and the Cost of Never Switching Off', excerpt: 'Drive is a gift until it runs the whole system. Where the off-switch went.', by: 'Brooke Sprowl', date: 'Mar 28, 2026', img: 'blog-presenteeism', ext: 'webp' },
      { cat: 'Meaning', title: 'Who Do You Want to Be?', excerpt: 'Moving past what we want to have and do, toward our deepest inner values.', by: 'Brooke Sprowl', date: 'Feb 28, 2026', img: 'blog-fobo', ext: 'webp' },
    ],
  },
  {
    id: 'spirituality', title: 'Spirituality & Meaning', blurb: 'the bigger questions',
    items: [
      { cat: 'Spirituality', title: 'The Richness of Cultivating the Transtemporal Now', excerpt: 'On presence that holds past and future as allies, not adversaries.', by: 'Brooke Sprowl', date: 'Feb 12, 2026', img: 'blog-mindful', ext: 'webp' },
      { cat: 'Self-Transformation', title: 'You’re Not What You Think: The Real Path to Self-Transformation', excerpt: 'Why not all problems are created equal, and what that means for change.', by: 'Brooke Sprowl', date: 'Jan 29, 2026', img: 'blog-reparent', ext: 'webp' },
      { cat: 'Meaning', title: 'Wonder, Presence, and the Bigger Questions', excerpt: 'Sitting with the questions that don’t resolve — and why that’s the point.', by: 'Brooke Sprowl', date: 'Jan 15, 2026', img: 'blog-self-understanding', ext: 'webp' },
    ],
  },
];
groups.forEach((g, i) => { g.num = String(i + 1).padStart(2, '0'); });

const topicChips = groups.map((g) => ({ id: g.id, name: g.title.split(/[,&]/)[0].trim() })).concat([{ id: 'resources', name: 'Resources' }]);

const resources = [
  { cat: 'Finding care', title: 'How to Find the Right Therapist for Adult ADHD', excerpt: 'What to look for, where to start, and why fit matters more for ADHD than almost anything.', img: 'blog-adhd', ext: 'webp' },
  { cat: 'Paying for it', title: 'What Insurance Doesn’t Cover in Mental Health Treatment', excerpt: 'The gaps no one explains — and how to think about the real cost of good care.', img: 'blog-insurance', ext: 'webp' },
  { cat: 'Resources', title: 'How to Get an ESA Letter From a Licensed Professional Online', excerpt: 'What a legitimate emotional-support-animal letter requires — without the scams.', img: 'blog-esa', ext: 'webp' },
];

const essays = [
  { title: 'The Richness of Cultivating the Transtemporal Now', excerpt: 'On presence that holds past and future as allies, not adversaries.' },
  { title: 'You’re Not What You Think — The Real Path to Self-Transformation', excerpt: 'Why not all problems are created equal, and what that means for change.' },
  { title: 'Who Do You Want to Be?', excerpt: 'Moving past what we want to have and do, toward our deepest inner values.' },
];

const videos = [
  { title: 'What is living with a purpose?', img: 'blog-about', ext: 'webp' },
  { title: 'What is living with a purpose? Pt. 2', img: 'blog-488', ext: 'webp' },
  { title: 'On insight, change & the nervous system', img: 'blog-rect27', ext: 'webp' },
];
---
<Layout title="The Journal — Mental Health, Psychology & Spirituality | My LA Therapy" description="Honest, clinically-grounded writing on mental health, psychology, and spirituality from therapist and author Brooke Sprowl and the My LA Therapy clinicians — anxiety, trauma, relationships, self-worth, and meaning." path="/blog">
  <div id="top">
    <Nav client:load />
    <main style="background:var(--cream);">

      <!-- HERO + SEARCH -->
      <section style="background:var(--forest);padding:62px 24px 50px;">
        <div class="wrap" style="max-width:780px;text-align:center;">
          <div style="font-size:13px;letter-spacing:.16em;text-transform:uppercase;color:var(--tan);font-weight:700;margin-bottom:18px;">The Journal</div>
          <h1 class="h1-fluid" style="font-family:var(--serif);font-weight:500;font-size:56px;line-height:1.04;letter-spacing:-.02em;margin:0 auto 18px;color:var(--cream);">Ideas worth <span style="font-style:italic;color:var(--tan);">sitting with.</span></h1>
          <p style="font-size:17px;line-height:1.62;color:var(--sage-pale);margin:0 auto 30px;max-width:600px;">Therapist and author <span style="font-family:var(--serif);font-style:italic;color:var(--cream);">Brooke Sprowl</span> and our clinicians on mental health, psychology, and spirituality — honest, clinically-grounded writing meant to make you think and exist differently.</p>
          <form role="search" style="max-width:540px;margin:0 auto 24px;display:flex;gap:10px;background:var(--white);border:1px solid #d8cdbb;border-radius:999px;padding:6px 6px 6px 20px;align-items:center;box-shadow:0 18px 40px -22px rgba(0,0,0,.5);">
            <span aria-hidden="true" style="color:var(--muted-5);font-size:17px;">⌕</span>
            <input type="search" aria-label="Search the blog" placeholder="Search the blog — anxiety, trauma, relationships…" style="flex:1;min-width:0;border:none;outline:none;background:transparent;font-family:var(--sans);font-size:15px;color:var(--ink);" />
            <button type="submit" aria-label="Search" style="border:none;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;justify-content:center;width:42px;height:42px;border-radius:50%;background:var(--terracotta);flex:none;box-shadow:0 8px 18px -8px rgba(194,119,75,.7);">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--cream)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="13 6 19 12 13 18"></polyline></svg>
            </button>
          </form>
          <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;align-items:center;">
            <span style="font-size:12px;letter-spacing:.1em;text-transform:uppercase;color:var(--sage);font-weight:600;margin-right:4px;">Browse by topic</span>
            {topicChips.map((t) => (
              <a href={`#${t.id}`} class="blog-chip" style="text-decoration:none;font-size:13px;color:#dce6da;border:1px solid #3c5648;border-radius:999px;padding:6px 14px;">{t.name}</a>
            ))}
          </div>
        </div>
      </section>

      <!-- FEATURED -->
      <section style="background:var(--cream);padding:36px 24px 12px;">
        <div class="wrap">
          <div style="font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--terracotta);font-weight:700;margin-bottom:16px;">Popular right now</div>
          <a href="#" class="blog-feature" style="text-decoration:none;display:grid;grid-template-columns:1.05fr .95fr;gap:0;background:var(--white);border:1px solid var(--border);border-radius:18px;overflow:hidden;box-shadow:0 1px 3px rgba(33,58,48,.04);">
            <div style="padding:44px;display:flex;flex-direction:column;justify-content:center;">
              <span style="font-size:11.5px;letter-spacing:.08em;text-transform:uppercase;font-weight:700;color:var(--terracotta);margin-bottom:14px;">{featured.eyebrow}</span>
              <h2 style="font-family:var(--serif);font-weight:500;font-size:33px;line-height:1.14;color:var(--forest-ink);margin:0 0 14px;">{featured.title}</h2>
              <p style="font-size:15.5px;line-height:1.6;color:var(--muted);margin:0 0 20px;max-width:480px;">{featured.excerpt}</p>
              <div style="display:flex;align-items:center;gap:10px;font-size:13.5px;color:#8a8074;flex-wrap:wrap;"><span style="font-family:var(--serif);font-style:italic;color:#3a6552;">{featured.by}</span><span>·</span><span>{featured.date}</span><span>·</span><span>{featured.read}</span></div>
            </div>
            <div style="position:relative;min-height:320px;background:#dce6dd;overflow:hidden;">
              <img src={`/images/${featured.img}.${featured.ext}`} alt={featured.title} width="720" height="640" style="width:100%;height:100%;object-fit:cover;display:block;" />
            </div>
          </a>
        </div>
      </section>

      <!-- TOPIC SECTIONS -->
      <section style="background:var(--cream);padding:40px 24px 20px;">
        <div class="wrap">
          {groups.map((g) => (
            <div id={g.id} style="margin-bottom:54px;scroll-margin-top:20px;">
              <div class="blog-sec-head" style="display:flex;align-items:flex-end;justify-content:space-between;gap:16px;margin-bottom:24px;padding-bottom:15px;border-bottom:1px solid var(--border);">
                <div style="display:flex;align-items:baseline;gap:16px;flex-wrap:wrap;">
                  <span style="font-family:var(--serif);font-style:italic;font-size:42px;line-height:1;color:var(--terracotta);">{g.num}</span>
                  <h2 style="font-family:var(--serif);font-weight:500;font-size:27px;margin:0;color:var(--forest-ink);">{g.title}</h2>
                  <span style="font-size:14px;color:#8a8074;">{g.blurb}</span>
                </div>
                <a href="#" class="blog-all" style="text-decoration:none;color:var(--forest);font-weight:600;font-size:14px;border-bottom:2px solid var(--terracotta);padding-bottom:3px;white-space:nowrap;flex:none;">View all →</a>
              </div>
              <div class="blog-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;">
                {g.items.map((p) => (
                  <a href="#" class="blog-card" style="text-decoration:none;background:var(--white);border:1px solid var(--border);border-radius:16px;overflow:hidden;display:flex;flex-direction:column;box-shadow:0 1px 3px rgba(33,58,48,.04);">
                    <div style="height:168px;overflow:hidden;background:#dce6dd;">
                      <img src={`/images/${p.img}.${p.ext}`} alt={p.title} width="420" height="168" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" />
                    </div>
                    <div style="padding:20px 22px 22px;display:flex;flex-direction:column;flex:1;">
                      <span style="font-size:11px;letter-spacing:.07em;text-transform:uppercase;font-weight:700;color:var(--terracotta);margin-bottom:9px;">{p.cat}</span>
                      <h3 style="font-family:var(--serif);font-weight:500;font-size:20px;line-height:1.2;color:var(--forest-ink);margin:0 0 9px;">{p.title}</h3>
                      <p style="font-size:13.5px;line-height:1.55;color:var(--muted);margin:0 0 16px;">{p.excerpt}</p>
                      <div style="margin-top:auto;display:flex;align-items:center;gap:9px;font-size:12.5px;color:#8a8074;"><span style="font-family:var(--serif);font-style:italic;color:#3a6552;">{p.by}</span><span>·</span><span>{p.date}</span></div>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- RESOURCES BAND -->
      <section id="resources" style="background:var(--sand-2);padding:52px 24px;scroll-margin-top:20px;">
        <div class="wrap">
          <div class="blog-sec-head" style="display:flex;align-items:flex-end;justify-content:space-between;gap:16px;flex-wrap:wrap;margin-bottom:24px;">
            <div>
              <div style="font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--terracotta);font-weight:700;margin-bottom:9px;">Navigating therapy &amp; resources</div>
              <h2 style="font-family:var(--serif);font-weight:500;font-size:30px;margin:0;color:var(--forest-ink);">Practical guides for <span style="font-style:italic;color:var(--terracotta);">getting good care.</span></h2>
            </div>
            <a href="#" class="blog-all" style="text-decoration:none;color:var(--forest);font-weight:600;font-size:15px;border-bottom:2px solid var(--terracotta);padding-bottom:3px;white-space:nowrap;">All resources →</a>
          </div>
          <div class="blog-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:18px;">
            {resources.map((r) => (
              <a href="#" class="blog-card" style="text-decoration:none;background:var(--white);border:1px solid var(--border);border-radius:16px;overflow:hidden;display:flex;flex-direction:column;">
                <div style="height:148px;overflow:hidden;background:#dce6dd;">
                  <img src={`/images/${r.img}.${r.ext}`} alt={r.title} width="420" height="148" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" />
                </div>
                <div style="padding:20px 22px 22px;display:flex;flex-direction:column;flex:1;">
                  <span style="font-size:11px;letter-spacing:.07em;text-transform:uppercase;font-weight:700;color:var(--terracotta);margin-bottom:9px;">{r.cat}</span>
                  <h3 style="font-family:var(--serif);font-weight:500;font-size:19px;line-height:1.22;color:var(--forest-ink);margin:0 0 8px;">{r.title}</h3>
                  <p style="font-size:13.5px;line-height:1.55;color:var(--muted);margin:0;">{r.excerpt}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- MORE FROM BROOKE (essays) -->
      <section style="background:var(--cream);padding:34px 24px 10px;">
        <div class="wrap">
          <div style="background:#efe7da;border-radius:18px;padding:38px 40px;">
            <div class="blog-sec-head" style="display:flex;align-items:flex-end;justify-content:space-between;gap:14px;flex-wrap:wrap;margin-bottom:20px;">
              <div>
                <div style="font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--terracotta);font-weight:700;margin-bottom:8px;">More from Brooke</div>
                <h2 style="font-family:var(--serif);font-weight:500;font-size:27px;margin:0;color:var(--forest-ink);">Essays on meaning &amp; <span style="font-style:italic;color:var(--terracotta);">self-transformation.</span></h2>
              </div>
              <a href="#" class="blog-all" style="text-decoration:none;color:var(--forest);font-weight:600;font-size:15px;border-bottom:2px solid var(--terracotta);padding-bottom:3px;white-space:nowrap;">All essays →</a>
            </div>
            <div class="blog-essays" style="display:grid;grid-template-columns:repeat(3,1fr);gap:0;">
              {essays.map((e, i) => (
                <a href="#" class="blog-essay" style={`text-decoration:none;color:inherit;padding:6px 28px 6px 24px;display:block;${i === 0 ? '' : 'border-left:1px solid #ddcdb6;'}`}>
                  <h3 style="font-family:var(--serif);font-weight:500;font-size:20px;line-height:1.22;color:var(--forest-ink);margin:0 0 9px;">{e.title}</h3>
                  <p style="font-size:13.5px;line-height:1.55;color:#6f6557;margin:0;">{e.excerpt}</p>
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- PODCAST + VIDEOS -->
      <section style="background:var(--cream);padding:26px 24px 12px;">
        <div class="wrap blog-media" style="display:grid;grid-template-columns:.85fr 1.15fr;gap:24px;align-items:stretch;">
          <div style="background:var(--forest);border-radius:18px;padding:38px 36px;display:flex;flex-direction:column;justify-content:center;">
            <div style="font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--sage);font-weight:700;margin-bottom:12px;">Listen</div>
            <h2 style="font-family:var(--serif);font-weight:500;font-size:28px;line-height:1.12;color:var(--white);margin:0 0 12px;">The podcast, for the <span style="font-style:italic;color:var(--tan);">long-form version.</span></h2>
            <p style="font-size:15px;line-height:1.6;color:var(--sage-pale);margin:0 0 22px;max-width:380px;">Deeper conversations on psychology, spirituality, and what it actually takes to change.</p>
            <a href="#" style="text-decoration:none;align-self:flex-start;background:var(--tan);color:var(--forest);font-weight:600;font-size:14.5px;padding:13px 26px;border-radius:999px;">Listen on Spotify →</a>
          </div>
          <div>
            <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:14px;margin-bottom:16px;">
              <h2 style="font-family:var(--serif);font-weight:500;font-size:24px;margin:0;color:var(--forest-ink);">Watch</h2>
              <a href="#" class="blog-all" style="text-decoration:none;color:var(--forest);font-weight:600;font-size:14px;border-bottom:2px solid var(--terracotta);padding-bottom:3px;white-space:nowrap;">All videos →</a>
            </div>
            <div class="blog-videos" style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px;">
              {videos.map((v) => (
                <a href="#" class="blog-card" style="text-decoration:none;color:inherit;background:var(--white);border:1px solid var(--border);border-radius:14px;overflow:hidden;display:block;">
                  <div style="position:relative;height:104px;overflow:hidden;background:#dce6dd;">
                    <img src={`/images/${v.img}.${v.ext}`} alt={v.title} width="260" height="104" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" />
                    <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;"><span style="width:38px;height:38px;border-radius:50%;background:rgba(246,241,233,.92);display:flex;align-items:center;justify-content:center;box-shadow:0 8px 20px -8px rgba(0,0,0,.5);"><span style="border-left:11px solid var(--terracotta);border-top:7px solid transparent;border-bottom:7px solid transparent;margin-left:3px;"></span></span></div>
                  </div>
                  <div style="padding:13px 14px 15px;"><h3 style="font-family:var(--serif);font-weight:500;font-size:14.5px;line-height:1.2;color:var(--forest-ink);margin:0;">{v.title}</h3></div>
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- NEWSLETTER CTA -->
      <section style="background:var(--cream);padding:34px 24px 44px;">
        <div class="wrap" style="background:var(--sand-2);border-radius:18px;padding:48px;text-align:center;">
          <div style="font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--terracotta);font-weight:700;margin-bottom:12px;">Free resources</div>
          <h2 style="font-family:var(--serif);font-weight:500;font-size:32px;line-height:1.15;margin:0 auto 14px;max-width:600px;color:var(--forest-ink);">Get our best writing — and the occasional free guide.</h2>
          <p style="font-size:16px;color:var(--muted);margin:0 auto 26px;max-width:500px;">Thoughtful, never spammy. Unsubscribe anytime.</p>
          <form style="max-width:460px;margin:0 auto;display:flex;gap:10px;background:var(--white);border:1px solid #d8cdbb;border-radius:999px;padding:6px 6px 6px 20px;align-items:center;">
            <input type="email" aria-label="Email address" placeholder="you@email.com" style="flex:1;min-width:0;border:none;outline:none;background:transparent;font-family:var(--sans);font-size:15px;color:var(--ink);" />
            <button type="submit" style="border:none;cursor:pointer;text-decoration:none;background:var(--terracotta);color:var(--cream);font-weight:600;font-size:13.5px;padding:11px 22px;border-radius:999px;white-space:nowrap;">Subscribe</button>
          </form>
        </div>
      </section>

    </main>
    <Footer />
  </div>

  <style>
    /* .wrap (max-width:1360px) is defined globally so section content aligns
       with the Nav and Footer. No page-level override needed. */
    .blog-chip { transition: border-color .16s ease, color .16s ease; }
