---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.tsx';
import Footer from '../components/Footer.astro';
import MatchCta from '../components/MatchCta.astro';
import ReviewsWall from '../components/ReviewsWall.astro';

const formats = [
  { id: 'fmt-individual', name: 'Individual', swatch: 'var(--terracotta)', blurb: 'One-on-one, the deepest work.' },
  { id: 'fmt-couples', name: 'Couples', swatch: 'var(--tan)', blurb: 'Break the cycle, together.' },
  { id: 'fmt-family', name: 'Family', swatch: 'var(--sage)', blurb: 'When healing is everyone’s.' },
  { id: 'fmt-child-teen', name: 'Child & Teen', swatch: 'var(--gold)', blurb: 'Support that meets kids where they are.' },
  { id: 'fmt-group', name: 'Group', swatch: 'var(--clay)', blurb: 'You’re not alone in this.' },
];

const rows = [
  { id: 'fmt-individual', n: '01', name: 'Individual Therapy', img: 'tot-individual', ext: 'webp', w: 232, h: 201, forwhen: 'For when it’s time to focus on you.', body: 'One-on-one work on anything from anxiety to identity — the deepest, most personal version of the work.' },
  { id: 'fmt-couples', n: '02', name: 'Couples Therapy', img: 'tot-couples', ext: 'webp', w: 190, h: 193, forwhen: 'For when you’re ready to change your patterns.', body: 'Break the cycle, rebuild trust, and learn to actually hear each other — together in the room.' },
  { id: 'fmt-family', n: '03', name: 'Family Therapy', img: 'tot-family', ext: 'png', w: 254, h: 180, forwhen: 'For when healing needs to happen together.', body: 'When one person’s struggle is everyone’s, we work with the family as a whole — not just the person who got sent in.' },
  { id: 'fmt-child-teen', n: '04', name: 'Child & Teen', img: 'tot-childteen', ext: 'png', w: 512, h: 328, cover: true, forwhen: 'For when your kid is hurting and words are hard.', body: 'Developmentally-attuned support that meets younger clients where they actually are — with the parents alongside.' },
  { id: 'fmt-group', n: '05', name: 'Group Therapy', img: 'tot-group', ext: 'webp', w: 255, h: 170, forwhen: 'For when you need to know you’re not the only one.', body: 'Healing alongside others facing the same thing — connection as part of the medicine.' },
];

const reviews = [
  { tag: 'Individual', quote: 'Brooke has the true gift of insight and compassion — getting straight to the heart of your blind spots in a way that’s truly changed my life.', by: 'S.M., Santa Monica' },
  { tag: 'Couples', quote: 'I felt very seen, understood, and supported — Brooke went right to the source of the issue while staying so gentle and kind.', by: 'J.R., Brentwood' },
  { tag: 'Individual', quote: 'I’d been in therapy on and off for 20 years. Brooke did more in one session than years of work with my previous therapist.', by: 'D.L., Silver Lake' },
];
---
<Layout title="Types of Therapy — Individual, Couples, Family & More in Los Angeles | My LA Therapy" description="Individual, couples, family, child & teen, and group therapy in Los Angeles — plus non-clinical coaching. Explore every format and get matched with the right therapist." path="/types-of-therapy">
  <div id="top">
    <Nav client:load />
    <main style="background:var(--cream);">

        <!-- FOREST HERO (split) -->
        <section id="s-hero" style="background:var(--forest);color:var(--cream-text);padding:54px 24px 10px;">
          <div class="wrap tot-hero-grid" style="display:grid;grid-template-columns:1.12fr .88fr;gap:46px;align-items:center;">
            <div>
              <div style="font-size:13px;letter-spacing:.14em;text-transform:uppercase;color:var(--sage);font-weight:600;margin-bottom:16px;">Ways to work together</div>
              <h1 class="h1-fluid" style="font-family:var(--serif);font-weight:500;font-size:52px;line-height:1.04;letter-spacing:-.02em;margin:0 0 18px;color:var(--white);">However you want to <span style="font-style:italic;color:var(--tan);">do the work.</span></h1>
              <p style="font-size:17px;line-height:1.6;color:var(--sage-pale);margin:0 0 26px;max-width:520px;">On your own, with a partner, as a family — whatever shape the work needs to take, we’ll match you with the right therapist for it.</p>
              <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:center;">
                <a href="#book" style="text-decoration:none;background:var(--terracotta);color:var(--white);font-weight:600;font-size:15px;padding:13px 26px;border-radius:999px;box-shadow:0 14px 30px -12px rgba(0,0,0,.45);">Find my therapist →</a>
                <a href="#formats" style="text-decoration:none;background:rgba(255,255,255,.1);color:var(--white);font-weight:600;font-size:14.5px;padding:13px 22px;border-radius:999px;border:1px solid rgba(255,255,255,.28);">See the formats</a>
              </div>
            </div>
            <div style="border-radius:18px;aspect-ratio:1/1;overflow:hidden;border:1px solid rgba(255,255,255,.12);">
              <img src="/images/brooke-team.webp" alt="Brooke Sprowl, founder of My LA Therapy in Los Angeles" width="900" height="900" style="width:100%;height:100%;object-fit:cover;object-position:top center;display:block;" />
            </div>
          </div>
        </section>

        <!-- FORMATS AT A GLANCE (jump-nav) -->
        <section style="background:var(--forest);padding:8px 24px 54px;">
          <div class="wrap" style="max-width:1108px;">
            <div style="font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--sage);font-weight:700;margin-bottom:16px;">Five ways in — at a glance</div>
            <div class="fmt-glance" style="display:grid;grid-template-columns:repeat(5,1fr);gap:12px;">
              {formats.map((f) => (
                <a href={`#${f.id}`} class="tot-tile" style="text-decoration:none;color:inherit;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.12);border-radius:16px;padding:20px 18px 18px;display:flex;flex-direction:column;gap:9px;">
                  <span style={`width:28px;height:6px;border-radius:999px;background:${f.swatch};`}></span>
                  <h3 style="font-family:var(--serif);font-weight:500;font-size:18px;margin:0;color:var(--white);line-height:1.16;">{f.name}</h3>
                  <p style="font-size:13px;line-height:1.5;color:var(--sage-pale);margin:0;">{f.blurb}</p>
                </a>
              ))}
            </div>
          </div>
        </section>

        <!-- FORMATS (editorial alternating rows) -->
        <section id="formats" style="background:var(--cream);padding:56px 24px 30px;">
          <div style="text-align:center;max-width:680px;margin:0 auto 18px;">
            <div style="font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--terracotta);font-weight:700;margin-bottom:12px;">Therapy formats</div>
            <h2 class="h2-fluid" style="font-family:var(--serif);font-weight:500;font-size:40px;line-height:1.06;margin:0 0 12px;color:var(--forest-ink);">Find the format that <span style="font-style:italic;color:var(--terracotta);">fits.</span></h2>
            <p style="font-size:16.5px;line-height:1.6;color:var(--muted);margin:0;">Not sure which is right? Start anywhere — we’ll help you find the fit.</p>
          </div>
          <div class="wrap" style="max-width:1060px;">
            {rows.map((r, idx) => {
              const media = (
                <div class="fmt-media" style={`background:var(--paper-5);border-radius:20px;min-height:240px;display:flex;align-items:${r.cover ? 'stretch' : 'flex-end'};justify-content:center;overflow:hidden;`}>
                  <img src={`/images/${r.img}.${r.ext}`} alt={`${r.name} in Los Angeles`} width={r.w} height={r.h} loading="lazy" style={r.cover ? 'width:100%;height:100%;min-height:240px;object-fit:cover;display:block;' : 'max-height:208px;max-width:88%;width:auto;object-fit:contain;display:block;'} />
                </div>
              );
              const body = (
                <div>
                  <div style="font-family:var(--serif);font-style:italic;font-size:42px;line-height:1;color:var(--terracotta);margin-bottom:10px;">{r.n}</div>
                  <h3 style="font-family:var(--serif);font-weight:500;font-size:31px;line-height:1.08;color:var(--forest-ink);margin:0 0 10px;">{r.name}</h3>
                  <p style="font-family:var(--serif);font-style:italic;font-size:20px;line-height:1.4;color:var(--terracotta);margin:0 0 12px;">{r.forwhen}</p>
                  <p style="font-size:15.5px;line-height:1.65;color:var(--muted);margin:0 0 16px;max-width:460px;">{r.body}</p>
                  <a href="#book" style="text-decoration:none;font-size:14px;font-weight:600;color:var(--forest);display:inline-flex;align-items:center;gap:6px;"><span style="border-bottom:2px solid var(--terracotta);padding-bottom:2px;">Find my therapist</span><span style="color:var(--terracotta);">→</span></a>
                </div>
              );
              const imageLeft = idx % 2 === 0;
              return (
                <div id={r.id} class="fmt-row" style={`display:grid;grid-template-columns:${imageLeft ? '.82fr 1.18fr' : '1.18fr .82fr'};gap:44px;align-items:center;padding:34px 0;border-top:1px solid var(--border);${idx === rows.length - 1 ? 'border-bottom:1px solid var(--border);' : ''}scroll-margin-top:20px;`}>
                  {imageLeft ? <>{media}{body}</> : <>{body}{media}</>}
                </div>
              );
            })}
          </div>
        </section>

        <!-- COACHING BAND (set apart · non-clinical) -->
        <section style="background:var(--forest);padding:54px 24px;">
          <div class="wrap" style="max-width:1000px;">
            <div style="text-align:center;margin-bottom:30px;">
              <div style="display:inline-flex;align-items:center;gap:9px;border:1px solid rgba(231,184,148,.4);border-radius:999px;padding:6px 16px;margin-bottom:16px;"><span style="width:6px;height:6px;border-radius:50%;background:var(--tan);"></span><span style="font-size:11px;letter-spacing:.13em;text-transform:uppercase;color:var(--tan);font-weight:700;">A different offering · not therapy</span></div>
              <h2 style="font-family:var(--serif);font-weight:500;font-size:34px;line-height:1.1;margin:0 0 10px;color:var(--cream);">Coaching, when the goal is <span style="font-style:italic;color:var(--tan);">forward.</span></h2>
              <p style="font-size:16px;line-height:1.6;color:var(--sage-pale);margin:0 auto;max-width:620px;">For growth and performance rather than healing — a separate, non-clinical track for when you’re well and want to go further.</p>
            </div>
            <div class="coach-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
              <a href="#book" class="coach-card" style="text-decoration:none;color:inherit;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.13);border-radius:16px;padding:26px 28px;">
                <h3 style="font-family:var(--serif);font-weight:500;font-size:22px;color:var(--white);margin:0 0 8px;">Executive Coaching</h3>
                <p style="font-size:14.5px;line-height:1.55;color:var(--sage-pale);margin:0;">Performance, leadership, and the person under the title — for founders and executives who want an edge that lasts.</p>
              </a>
              <a href="#book" class="coach-card" style="text-decoration:none;color:inherit;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.13);border-radius:16px;padding:26px 28px;">
                <h3 style="font-family:var(--serif);font-weight:500;font-size:22px;color:var(--white);margin:0 0 8px;">Creative Coaching</h3>
                <p style="font-size:14.5px;line-height:1.55;color:var(--sage-pale);margin:0;">Unblocking the work and the life around it — for artists and makers moving through resistance toward output.</p>
              </a>
            </div>
          </div>
        </section>

        <!-- TRUST BAND -->
        <section style="background:var(--sand-2);padding:38px 24px;">
          <div class="wrap" style="background:var(--forest);border-radius:16px;padding:26px 34px;display:flex;align-items:center;gap:34px;flex-wrap:wrap;box-shadow:0 24px 56px -38px rgba(33,58,48,.6);">
            <div style="font-family:var(--serif);font-style:italic;font-size:22px;color:var(--tan);line-height:1.3;flex:1;min-width:260px;">The format matters less than who’s in the room.</div>
            <div style="flex:1.4;min-width:300px;font-size:15px;color:var(--sage-pale);line-height:1.6;">Individual, couples, family, or group — every therapist is personally vetted and trained by our founder, so whichever shape you choose, the person across from you is the real difference.</div>
          </div>
        </section>

        <!-- REVIEWS -->
        <ReviewsWall
          bg="var(--mist)"
          eyebrow="Client reviews"
          heading="People who felt"
          accent="finally understood."
          reviews={reviews}
        />

        <!-- LEAD CAPTURE -->
        <MatchCta
          bg="var(--sand-2)"
          heading="Tell us the shape of it."
          accent="We’ll find your person."
          text="Whether it’s just you, the two of you, or the whole family — a few details and we’ll match you with the right therapist, usually within 24–48 hours."
          bullets={[
            'Matched to your format and your needs',
            'Personally vetted by our founder',
            'First session guaranteed — or we re-match you free',
          ]}
        />

    </main>
    <Footer />
  </div>

  <style>
    /* .wrap (max-width:1360px) is defined globally in global.css so section
       content aligns with the Nav and Footer. No page-level override needed. */
    .tot-tile { transition: background .16s ease; }
    .tot-tile:hover { background: rgba(255,255,255,.09) !important; }
    .coach-card { transition: background .16s ease; }
    .coach-card:hover { background: rgba(255,255,255,.09) !important; }

    @media (max-width: 860px) {
      .tot-hero-grid { grid-template-columns: 1fr !important; gap: 30px !important; }
      .fmt-glance { grid-template-columns: repeat(2, 1fr) !important; }
      .fmt-row { grid-template-columns: 1fr !important; gap: 22px !important; }
      .fmt-row .fmt-media { order: -1; }
      .coach-grid { grid-template-columns: 1fr !important; }
      .rev-grid { grid-template-columns: 1fr !important; }
    }
  </style>
</Layout>
